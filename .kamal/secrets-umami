KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

# Postgres password for the Umami DB accessory
POSTGRES_PASSWORD=$UMAMI_DB_PASSWORD

# Full connection string — references UMAMI_DB_PASSWORD from environment
DATABASE_URL=postgresql://umami:${UMAMI_DB_PASSWORD}@umami-db:5432/umami

# Random secret used by Umami to sign sessions (generate with: openssl rand -hex 32)
APP_SECRET=$UMAMI_APP_SECRET
