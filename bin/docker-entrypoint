#!/bin/bash -e

# Enable jemalloc for reduced memory usage and latency.
if [ -z "${LD_PRELOAD+x}" ]; then
    LD_PRELOAD=$(find /usr/lib -name libjemalloc.so.2 -print -quit)
    export LD_PRELOAD
fi

# Write GCS credentials file from base64-encoded env var
if [ -n "${GOOGLE_SERVICE_ACCOUNT_JSON}" ]; then
  CLEAN_GCS_JSON=$(printf '%s' "${GOOGLE_SERVICE_ACCOUNT_JSON}" | tr -d '%\r\n')
  if printf '%s' "${CLEAN_GCS_JSON}" | base64 -d > /tmp/gcs_credentials.json 2>/dev/null; then
    export GCS_CREDENTIALS_PATH=/tmp/gcs_credentials.json
  else
    echo "WARNING: Failed to decode GOOGLE_SERVICE_ACCOUNT_JSON — GCS storage will not work" >&2
    rm -f /tmp/gcs_credentials.json
  fi
fi

# If running the rails server then create or migrate existing database
if [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]; then
  ./bin/rails db:prepare
fi

exec "${@}"
