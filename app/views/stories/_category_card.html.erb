<%# Variation D — "Across the rooms" card. %>
<%# Mobile: 1-up. sm: 2-up. md: 3-up. %>
<%# Locals: story. %>
<% s = story.storyable %>
<% if s.respond_to?(:featured_image) && s.featured_image.attached? %>
  <div>
    <% if s.respond_to?(:category) && s.category %>
      <%= link_to s.category.name,
            category_path(s.category),
            class: "inline-block mb-2 md:mb-3 text-[9px] md:text-[10px] tracking-[0.16em] uppercase font-mono text-[var(--color-primary)] dark:text-[var(--color-accent)] hover:underline" %>
    <% end %>

    <%= link_to s, class: "block group" do %>
      <div class="overflow-hidden mb-3 md:mb-4 aspect-[16/9] md:aspect-[3/2]">
        <%= image_tag s.featured_image.variant(:thumb),
              alt: s.title,
              loading: "lazy",
              decoding: "async",
              class: "w-full h-full object-cover transition-transform duration-300 group-hover:scale-[1.02]" %>
      </div>

      <h3 class="lora font-semibold text-[17px] md:text-xl leading-tight mb-1 md:mb-2 text-balance text-[var(--color-text)] dark:text-gray-200 group-hover:underline decoration-[var(--color-secondary)]/40 underline-offset-4">
        <%= s.title %>
      </h3>

      <% if s.respond_to?(:excerpt) && s.excerpt.present? %>
        <p class="lora text-[13px] md:text-sm leading-[1.5] text-[var(--color-text)]/75 dark:text-gray-300">
          <%= truncate(strip_tags(s.excerpt.to_s), length: 140) %>
        </p>
      <% end %>
    <% end %>
  </div>
<% end %>
