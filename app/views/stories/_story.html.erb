<%# Cache key includes the storyable so edits to the underlying Article/Video
   bust the fragment (Story#updated_at is not touched by storyable changes),
   and I18n.locale so locale-specific chrome is not cross-served. %>
<% cache [ story, story.storyable, I18n.locale ] do %>
<div class="h-full rounded-sm overflow-hidden dark:bg-ink dark:text-gray-300 relative mt-2 mb-2">
  <% if story.storyable.respond_to?(:featured_image) && story.storyable.featured_image.attached? %>
    <% if story.storyable.is_a?(Video) %>
    <div class="absolute rounded-full p-2 shadow-lg" style="z-index: 10;margin: 5px;right: 5px;background-color: indianred;opacity: 0.8;">
      <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
        <path d="M8 5v14l11-7z" />
      </svg>
    </div>
    <% end %>
    <%= link_to story.storyable, class:"group" do %>
      <%= image_tag story.storyable.featured_image.variant(:thumb), alt: story.storyable.title, loading: "lazy", decoding: "async", class: "w-full h-48 object-cover filter grayscale-50 transition-all duration-300 inline max-w-full group-hover:filter-none group-hover:scale-105" %>
      <h2 class="text-xl font-bold px-4 py-2 lora"><%= story.storyable.title %></h2>
      <p class="text-md px-4 py-1 lora">
          <%= story.storyable.try(:subtitle)%>
      </p>
      <p class="group-hover:underline text-lg p-4 lora">
          <%#= story.storyable.try(:excerpt) ||  story.storyable.try(:description)%>
          <%= truncate(strip_tags(story.storyable.try(:excerpt)) || 
          truncate(strip_tags(story.storyable.try(:description))), length: 150) %>...
      </p>
    <% end %>
  <% end %>
</div>
<% end %>
