<%# Homepage layout: top story → recent grid → latest per category → featured videos.
    Each fork can customize this view directly; the partials in stories/_*.html.erb
    are brand-agnostic (driven by theme.css variables). %>

<% content_for :head do %>
  <% set_meta_tags(
       description: default_meta_description,
       canonical:   root_url,
       og: { title: site_name, url: root_url,
             description: default_meta_description,
             image: og_image_url_for(nil) }
     ) %>
  <%= render "shared/json_ld", schema: {
        "@context" => "https://schema.org",
        "@graph"   => [
          { "@type" => "WebSite", "@id" => "#{site_url}/#website",
            "url" => site_url, "name" => site_name,
            "description" => default_meta_description,
            "potentialAction" => {
              "@type" => "SearchAction",
              "target" => "#{site_url}/articles?search={search_term_string}",
              "query-input" => "required name=search_term_string"
            } },
          schema_publisher
        ] } %>
<% end %>

<h1 class="sr-only"><%= site_name %><%= " — #{cms_setting.tagline}" if cms_setting.tagline.present? %></h1>

<div id="stories" class="dark:text-gray-300">

  <%# ─── HERO ──────────────────────────────────────────── %>
  <% if @top_story %>
    <%= render "stories/hero", story: @top_story %>
  <% end %>

  <%# ─── RECENTLY PUBLISHED ────────────────────────────── %>
  <section id="recent_stories" class="container mx-auto px-5 md:px-20 pt-10 md:pt-24">
    <header class="flex items-baseline justify-between mb-6 md:mb-12 pb-3 md:pb-4 border-b border-[var(--color-accent)]/40">
      <h2 class="lora font-medium text-[22px] md:text-[32px] tracking-tight text-[var(--color-text)] dark:text-gray-200 m-0">
        Recently published
      </h2>
      <%= link_to "All →".html_safe,
            articles_path,
            class: "text-[9px] md:text-[11px] tracking-[0.16em] uppercase font-mono text-[var(--color-primary)] dark:text-[var(--color-accent)] hover:underline" %>
    </header>

    <% if @recent_stories.any? %>
      <%# Lead + 2 stacked (mobile: full single column) %>
      <div class="grid grid-cols-1 md:grid-cols-[1.6fr_1fr] gap-8 md:gap-16 mb-10 md:mb-24">
        <% if @recent_stories[0] %>
          <%= render "stories/feature_card", story: @recent_stories[0] %>
        <% end %>

        <div class="flex flex-col gap-7 md:gap-12 md:pt-2">
          <% [@recent_stories[1], @recent_stories[2]].compact.each do |s| %>
            <%= render "stories/small_card", story: s %>
          <% end %>
        </div>
      </div>

      <%# Rest: mobile 2-up, sm 2-up, md 3-up %>
      <% rest = @recent_stories[3..5] || [] %>
      <% if rest.any? %>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-10 mb-10 md:mb-24">
          <% rest.each do |s| %>
            <%= render "stories/small_card", story: s, tiny: true %>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </section>

  <%# ─── MOTION PICTURES (dark band) ──────────────────── %>
  <% if @videos.any? %>
    <section id="videos" class="bg-[var(--color-primary-darkest)] dark:bg-slate-800 text-gray-200 lora py-10 md:py-22 mt-10 md:mt-0">
      <div class="container mx-auto px-5 md:px-20">
        <header class="flex items-baseline justify-between mb-6 md:mb-14">
          <div>
            <div class="text-[9px] md:text-[11px] tracking-[0.18em] uppercase font-mono text-[var(--color-accent)] mb-2 md:mb-3">
              Now showing
            </div>
            <h2 class="lora font-medium text-[26px] md:text-5xl leading-none tracking-tight text-balance m-0">
              Motion pictures, things we liked.
            </h2>
          </div>
          <%= link_to "All videos →",
                videos_path,
                class: "hidden md:inline-block text-[11px] tracking-[0.18em] uppercase font-mono text-[var(--color-accent)] hover:underline shrink-0 ml-6" %>
        </header>

        <%= render VideosComponent.new(videos: @videos) %>

        <div class="md:hidden mt-6 text-right">
          <%= link_to "All videos →",
                videos_path,
                class: "text-[9px] tracking-[0.18em] uppercase font-mono text-[var(--color-accent)] hover:underline" %>
        </div>
      </div>
    </section>
  <% end %>

  <%# ─── ACROSS THE ROOMS ─────────────────────────────── %>
  <% if @latest_stories_by_category.any? %>
    <section id="latest_stories_by_category" class="container mx-auto px-5 md:px-20 pt-10 md:pt-24 pb-12 md:pb-20">
      <header class="flex items-baseline justify-between mb-6 md:mb-12 pb-3 md:pb-4 border-b border-[var(--color-accent)]/40">
        <h2 class="lora font-medium text-[22px] md:text-[32px] tracking-tight text-[var(--color-text)] dark:text-gray-200 m-0">
          Across the rooms
        </h2>
        <%= link_to "All →".html_safe,
              articles_path,
              class: "text-[9px] md:text-[11px] tracking-[0.16em] uppercase font-mono text-[var(--color-primary)] dark:text-[var(--color-accent)] hover:underline" %>
      </header>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8 md:gap-10">
        <% @latest_stories_by_category.each do |s| %>
          <%= render "stories/category_card", story: s %>
        <% end %>
      </div>
    </section>
  <% end %>

  <div><%#= render InstagramComponent.new %></div>
</div>
