<% content_for :title, "Categories" %>

<div class="w-full container mx-auto lora p-4">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>
  <div id="categories" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
    <% if @categories.any? %>
      <% @categories.each do |category| %>
        <%= link_to category, class: "block h-48 w-full font-medium shadow transition-all flex items-center justify-center" do %>
          <%= render category %>
        <% end %>
      <% end %>
    <% else %>
      <p class="text-center my-10">No categories found.</p>
    <% end %>
  </div>
</div>
