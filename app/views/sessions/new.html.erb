<div class="min-h-screen flex items-center justify-center bg-cream dark:bg-ink">
  <div class="w-full max-w-sm">
    <div class="bg-white dark:bg-ink rounded-lg shadow-lg p-8">
      <h1 class="font-serif text-2xl text-sage-deep dark:text-peach mb-6 text-center">
        <%= site_name %> — Admin
      </h1>

      <% if alert = flash[:alert] %>
        <p class="mb-4 py-2 px-3 bg-red-50 dark:bg-red-900/30 text-red-700 dark:text-red-300
                  text-sm rounded border border-red-200 dark:border-red-700">
          <%= alert %>
        </p>
      <% end %>

      <%= form_with url: session_url, class: "space-y-4" do |form| %>
        <div>
          <%= form.label :email_address, "Email", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
          <%= form.email_field :email_address,
              required: true, autofocus: true,
              autocomplete: "username",
              placeholder: "",
              value: params[:email_address],
              class: "block w-full rounded border border-gray-300 dark:border-gray-600 px-3 py-2 text-sm
                      bg-white dark:bg-ink-soft text-gray-900 dark:text-gray-100
                      focus:outline-sage-deep dark:focus:outline-peach" %>
        </div>

        <div>
          <%= form.label :password, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
          <%= form.password_field :password,
              required: true,
              autocomplete: "current-password",
              placeholder: "••••••••",
              maxlength: 72,
              class: "block w-full rounded border border-gray-300 dark:border-gray-600 px-3 py-2 text-sm
                      bg-white dark:bg-ink-soft text-gray-900 dark:text-gray-100
                      focus:outline-sage-deep dark:focus:outline-peach" %>
        </div>

        <div class="pt-2">
          <%= form.submit "Sign in",
              class: "w-full rounded px-4 py-2.5 bg-sage-deep hover:bg-ink-soft text-white
                      text-sm font-medium cursor-pointer transition-colors" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
