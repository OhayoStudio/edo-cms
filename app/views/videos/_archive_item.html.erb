<div class="flex gap-4 p-4 group">
  <%# Thumbnail — links to video %>
  <%= link_to video_path(video), class: "flex-shrink-0 w-40 md:w-52", data: { turbo_frame: "_top" } do %>
    <div class="relative aspect-video overflow-hidden rounded-sm bg-gray-700">
      <img src="<%= video.thumbnail_url %>" alt="<%= video.title %>"
           class="w-full h-full object-cover group-hover:opacity-80 transition-opacity duration-200"
           loading="lazy" decoding="async">
      <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white opacity-75" viewBox="0 0 24 24" fill="currentColor">
          <path d="M3 22V2l18 10-18 10z"/>
        </svg>
      </div>
    </div>
  <% end %>

  <%# Title + description %>
  <div class="flex flex-col gap-1">
    <%= link_to video.title, video_path(video),
        class: "text-base md:text-lg font-medium lora leading-snug dark:text-gray-300 hover:underline",
        data: { turbo_frame: "_top" } %>
    <p class="text-sm lora" data-controller="description-expand">
      <%= video.description %>
    </p>
  </div>
</div>
