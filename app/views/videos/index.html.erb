<% content_for :title, "Videos" %>

<div class="container mx-auto">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div id="videos" class="min-w-full">
    <% if @videos.any? %>
    <div id="videos" class="min-w-full dark:text-gray-300 text-gray-900 p-4">
      <h2 class="text-4xl font-serif font-bold mb-4 pl-2 ">Videos</h2>
      <div class="flex flex-col md:flex-row gap-4">
      <!-- render Videos Component here under -->
      <%= render VideosComponent.new(videos: @videos)%>
      </div>
    </div>
    <% else %>
      <p class="text-center my-10">No videos found.</p>
    <% end %>
  </div>
</div>
