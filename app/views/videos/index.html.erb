<% content_for :title, "Videos" %>
<% if @videos.any? %>
<div id="videos" class="min-w-full dark:text-gray-300 dark:bg-gray-900 text-gray-300 bg-gray-900 p-4 lora">
  <div class="container mx-auto md:mx-auto md:mt-2 md:px-5">
    <h2 class="text-4xl font-serif font-bold mb-8 pl-2 pt-4">Videos</h2>
    <div class="flex flex-col md:flex-row gap-4">
      <%= render VideosComponent.new(videos: @videos) %>
    </div>
  </div>
</div>
<% else %>
  <p class="text-center my-10">No videos found.</p>
<% end %>

