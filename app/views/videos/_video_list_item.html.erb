<div class="container mx-auto grid grid-cols-1 md:grid-cols-5 overflow-hidden my-8">
    <div class="col-span-2">
        <!-- List all the Videos -->
        <div class="">
            <%= link_to video_path(video) do %>
            <%= image_tag video.featured_image.variant(:thumb), alt: video.title, loading: "lazy", decoding: "async", class: "w-full h-56 object-cover" if video.featured_image.attached? %>
            <% end %>
        </div>
    </div>
    <div class="col-span-3">
        <div id="videos" class="min-w-full">
            <article class="max-w-6xl mx-auto">
                <div class="p-2 pt-2 md:p-4 md:pt-0">
                    <h1 class="text-2xl font-bold text-gray-900 mb-4 lora dark:text-gray-300">
                        <%= link_to video_path(video) do %>
                        <%= video.title %>
                        <% end %>
                    </h1>

                    <p class="text-gray-600 mb-6 dark:text-gray-300 lora text-2md">
                        <%= link_to video_path(video) do %>
                        <%= video.description %>...
                        <% end %>
                    </p>
                </div>
            </article>
        </div>
    </div>
</div>

