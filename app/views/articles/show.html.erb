<% content_for :title,  @article.title %>
<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <%3 end %>

  <%= render "article", article: @article %>

  <%= render "articles/related_articles", related_articles: @article.related_articles %>

  <%= render "articles/tag_related_articles", tag_related_articles: @article.tag_related_articles %>
</div>
