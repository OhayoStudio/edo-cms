<%# "You might also like" — merged related + tag-related, deduped, capped at 6.
    Replaces both _related_articles.html.erb and _tag_related_articles.html.erb.

    Locals:
      - article: Article (the current one)
%>

<%
  related = (article.related_articles.to_a + article.tag_related_articles.to_a)
              .reject { |a| a.id == article.id }
              .uniq(&:id)
              .first(6)
%>

<% if related.any? %>
  <section class="border-t-2 border-ink dark:border-rule bg-cream-soft dark:bg-ink-soft py-16 md:py-24 lora">
    <div class="container mx-auto px-4 md:px-16 max-w-[1280px]">

      <%# Section header %>
      <div class="flex items-baseline justify-between pb-6 mb-10 border-b border-rule dark:border-ink-soft">
        <h2 class="lora font-medium text-3xl md:text-4xl lg:text-[40px] tracking-[-0.015em] text-ink dark:text-gray-200 m-0">
          You might also like
        </h2>
        <span class="hidden sm:inline font-mono text-[11px] tracking-[0.18em] uppercase text-sage-deep dark:text-rule">
          <%= related.size %> stories
        </span>
      </div>

      <%# 3-column grid (1-col on mobile, 2-col on tablet) %>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-10">
        <% related.each_with_index do |r, i| %>
          <article class="flex flex-col">

            <%# No. ### eyebrow above image %>
            <% if r.respond_to?(:catalogue_number) && r.catalogue_number %>
              <div class="font-mono text-[10px] tracking-[0.18em] uppercase text-sage-deep dark:text-rule text-right mb-2.5">
                No. <%= r.catalogue_number.to_s.rjust(3, "0") %>
              </div>
            <% end %>

            <%= link_to article_path(r.slug), class: "block group" do %>
              <% if r.featured_image.attached? %>
                <div class="w-full h-[200px] overflow-hidden bg-rule dark:bg-ink-soft mb-4">
                  <%= image_tag r.featured_image.variant(:thumb),
                        alt: r.title,
                        loading: "lazy",
                        decoding: "async",
                        class: "w-full h-full object-cover" %>
                </div>
              <% end %>

              <div class="font-mono text-[10px] tracking-[0.18em] uppercase text-gray-500 dark:text-gray-400 mb-2">
                <%= r.published_at.strftime("%b %-d, %Y") if r.published_at %>
              </div>

              <h3 class="lora font-medium text-xl md:text-[22px] leading-[1.2] tracking-[-0.01em] text-ink dark:text-gray-200 mb-2.5 text-balance group-hover:text-sage-deep dark:group-hover:text-rule transition-colors">
                <%= r.title %>
              </h3>

              <p class="lora text-[15px] leading-[1.5] text-gray-500 dark:text-gray-400 m-0">
                <%= truncate(r.excerpt, length: 110) %>
              </p>
            <% end %>
          </article>
        <% end %>
      </div>
    </div>
  </section>
<% end %>
