<!-- Article Show View Preview -->
<article
  class="mx-auto bg-gray-200 md:rounded-sm shadow-lg overflow-hidden dark:text-gray-300 dark:bg-gray-800"
>
  <!-- add featured_image here -->
  <div class="">
    <%= image_tag rails_blob_url(article.featured_image), class: "w-full h-full object-cover" if article.featured_image.attached? %>
  </div>

  <div class="dark:text-gray-300 dark:bg-gray-800">
    <div class="md:p-8 md:pt-0 padding-action-text text-lg lora max-w-screen-lg mx-auto">
      <div class="p-8 flex flex-col justify-center items-center">

        <div class="flex flex-col md:flex-row md:justify-between items-center gap-4 mb-4 w-full">
          <div id="title" class="w-full">
            <span class="py-1 text-sm font-medium text-gray-600 bg-gray-50 rounded-full">
              <%= link_to article.category.slug, category_path(article.category), class: "px-3 py-1 text-sm" %>
            </span>
            <h1 class="text-4xl font-bold text-gray-900 lora dark:text-gray-300 mt-8">
              <%= article.title %>
            </h1>
      
            <p class="text-xl text-gray-600 mb-2 dark:text-gray-200 lora"><%= article.subtitle %></p>
          </div>
          <div id="search" class="mt-4 md:mt-10">
            <%= render "articles/search" %>
          </div>
        </div>
      </div>
      <%= article.content %>
    </div>
    <!-- <div class="flex items-center gap-6 m-4">
      <div class="flex items-center gap-3">
        <%= image_tag rails_blob_url(article.author.avatar), class: "w-12 h-12
        rounded-full object-cover" %>
        <div>
          <p class="font-medium text-gray-900">
            <%= article.author.full_name %>
          </p>
          <div class="flex items-center gap-2 text-gray-500 text-sm">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4"
              fill="none"
