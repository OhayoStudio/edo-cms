<% content_for :title, "Stories" %>

<%# /articles index — magazine archive layout
    Mock: design tokens map directly to the brand theme palette:
      - bg              → bg-gray-200          (--color-background #F9F7F0)
      - ink             → text-[#423525]       (--color-text)
      - ink-soft        → text-gray-500
      - brand           → text-[#704214]       (--color-primary)
      - rule            → border-[#D9C4A6]     (--color-accent)
%>

<div class="w-full container mx-auto px-4 md:px-16 pt-8 md:pt-14 pb-16 md:pb-20 lora">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <%# ─ Big header: "Stories" wordmark + meta ───────────────────────── %>
  <header class="flex items-end justify-between pb-6 md:pb-7 mb-10 md:mb-14 border-b-2 border-[#423525] dark:border-[#D9C4A6]">
    <h1 class="font-serif font-medium text-5xl md:text-7xl lg:text-[96px] leading-none tracking-tight m-0 text-[#423525] dark:text-gray-300">
      <%= @category ? @category.name : "Stories" %>
    </h1>
    <div class="hidden sm:block text-right pb-1.5">
      <div class="font-mono text-[11px] tracking-[0.18em] uppercase text-[#704214] mb-1">The archive</div>
      <div class="font-serif text-sm text-[#423525] dark:text-gray-300">
        <%= @articles.total_count %> entries
      </div>
    </div>
  </header>

  <%# ─ Mobile category dropdown (kept as-is) ───────────────────────── %>
  <div class="flex md:hidden mb-6 relative" data-controller="dropdown">
    <button data-action="click->dropdown#toggle" class="w-full pl-3 pr-10 py-2 text-base border border-[#D9C4A6] focus:outline-none focus:ring-1 focus:ring-[#704214] focus:border-[#704214] sm:text-sm rounded-md bg-white flex items-center">
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
      </svg>
      <%= @category ? @category.name : "Categories" %>
    </button>
    <div data-dropdown-target="menu" class="hidden absolute mt-1 w-full rounded-md shadow-lg bg-white z-10">
      <div class="py-1" role="menu" aria-orientation="vertical">
        <% @categories.each do |category| %>
          <a href="<%= category_path(category.slug) %>" data-action="click->dropdown#navigate" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" role="menuitem"><%= category.name %> (<%= category.articles.published.count %>)</a>
        <% end %>
      </div>
    </div>
  </div>

  <%# ─ Two columns: list (2.2fr) | sidebar (1fr) ───────────────────── %>
  <div class="grid grid-cols-1 md:grid-cols-[2.2fr_1fr] gap-10 md:gap-20">

    <%# ─── Article list ─────────────────────────────────────────────── %>
    <div id="articles" class="min-w-0">
      <% if @articles.any? %>
        <% total = @articles.total_count %>
        <% offset = (@articles.current_page - 1) * @articles.limit_value %>
        <% @articles.each_with_index do |article, i| %>
          <%= render "articles/article_list_item", article: article, number: total - offset - i %>
        <% end %>
      <% else %>
        <p class="text-center my-10 dark:text-gray-300">No articles found.</p>
      <% end %>

      <%# Pagination — kaminari, restyled to match the magazine feel %>
      <div class="mt-4 pt-7 border-t-2 border-[#423525] dark:border-[#D9C4A6] dark:text-gray-300 flex justify-between items-center font-mono text-[10px] tracking-[0.18em] uppercase pagination">
        <%= paginate @articles %>
      </div>
    </div>

    <%# ─── Sidebar: search + categories ─────────────────────────────── %>
    <aside class="pt-1">
      <%# Search %>
      <div class="font-mono text-[10px] tracking-[0.18em] uppercase text-[#704214] mb-2.5">Search</div>
      <%= form_with url: articles_path, method: :get, class: "flex mb-9" do |f| %>
        <%= f.text_field :search,
              value: params[:search],
              placeholder: "Search stories",
              class: "flex-1 px-3.5 py-2.5 lora text-sm bg-white border border-[#D9C4A6] border-r-0 outline-none focus:border-[#704214] dark:bg-[#52300f] dark:border-[#52300f] dark:text-gray-200" %>
        <%= f.submit "Go",
              class: "px-4 font-mono text-[10px] tracking-[0.18em] uppercase bg-[#704214] text-[#F9F7F0] border border-[#704214] hover:bg-[#52300f] cursor-pointer" %>
      <% end %>

      <%# Categories list %>
      <div class="font-mono text-[10px] tracking-[0.18em] uppercase text-[#704214] mb-2.5">Categories</div>
      <div class="flex flex-col">
        <% @categories.each do |category| %>
          <%= link_to category_path(category.slug),
                class: "flex justify-between items-baseline py-3 border-b border-[#D9C4A6] dark:border-[#52300f] lora text-base text-[#423525] dark:text-gray-300 hover:text-[#704214] dark:hover:text-[#D9C4A6] transition-colors" do %>
            <span><%= category.name %></span>
            <span class="font-mono text-[11px] text-gray-500 dark:text-gray-400">
              <%= category.articles.published.count.to_s.rjust(2, "0") %>
            </span>
          <% end %>
        <% end %>
      </div>
    </aside>
  </div>
</div>
