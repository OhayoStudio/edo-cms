<% content_for :head do %>
  <% set_meta_tags(
       title:     "About",
       canonical: about_url,
       og: { title: "About | #{site_name}", url: about_url }
     ) %>
  <%= render "shared/json_ld", schema: {
        "@context"  => "https://schema.org",
        "@type"     => "WebPage",
        "name"      => "About #{site_name}",
        "url"       => about_url,
        "isPartOf"  => { "@id" => "#{site_url}/#website" },
        "publisher" => schema_publisher
      } %>
<% end %>

<%# ─── HERO BAND: tagline ─────────────────────────────────────── %>
<% if cms_setting.tagline.present? %>
  <section class="max-w-[1280px] mx-auto px-5 md:px-16 lg:px-20 pt-14 md:pt-24 pb-10 md:pb-14 lora">
    <div class="font-mono text-[10px] md:text-[11px] uppercase tracking-[0.18em] text-sage-deep mb-7 md:mb-9">
      About
    </div>

    <p class="font-serif italic font-normal text-[34px] sm:text-[48px] md:text-[68px] lg:text-[80px] leading-[1.06] tracking-[-0.02em] text-ink m-0 max-w-[1080px] text-balance">
      <%= cms_setting.tagline %>
    </p>
  </section>

  <div class="max-w-[1280px] mx-auto px-5 md:px-16 lg:px-20">
    <hr class="border-0 border-t-2 border-ink m-0">
  </div>
<% end %>

<%# ─── BODY: editor content + optional newsletter/contact sidebar ── %>
<section class="max-w-[1280px] mx-auto px-5 md:px-16 lg:px-20 pt-12 md:pt-16 pb-16 md:pb-24 grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-12 lg:gap-24 items-start lora">

  <%# Editor-controlled prose %>
  <article class="lexxy-content article-body about-body max-w-[660px] text-ink">
    <%= @about.content %>
  </article>

  <%# Sidebar — only renders sections that are configured %>
  <% show_newsletter = cms_setting.newsletter_provider.present? && cms_setting.newsletter_form_action.present? %>
  <% show_contact    = cms_setting.contact_email.present? %>
  <% if show_newsletter || show_contact %>
    <aside class="lg:sticky lg:top-8">
      <% if show_newsletter %>
        <div class="border border-rule p-7">
          <div class="font-mono text-[10px] uppercase tracking-[0.2em] text-sage-deep mb-3.5">By post</div>
          <h3 class="font-serif font-medium text-[22px] leading-[1.2] tracking-[-0.01em] text-ink m-0 mb-3 text-balance">
            One letter, when something new goes up.
          </h3>

          <form action="<%= cms_setting.newsletter_form_action %>" method="post" class="flex flex-col">
            <label for="newsletter-email" class="sr-only">Enter your email</label>
            <input type="email" name="email" id="newsletter-email"
                   placeholder="your@email.com"
                   required
                   class="px-3 py-2.5 border border-rule bg-transparent font-serif text-sm text-ink placeholder:text-[#A67B5B] placeholder:italic focus:outline-none focus:border-[#A67B5B]">
            <input type="submit" value="Notify me"
                   data-umami-event="newsletter_signup"
                   class="-mt-px py-3 px-3.5 bg-sage-deep text-cream-soft border border-sage-deep font-mono text-[11px] uppercase tracking-[0.16em] cursor-pointer hover:bg-ink-soft transition-colors">
          </form>
        </div>
      <% end %>

      <% if show_contact %>
        <div class="<%= 'mt-7 pt-7 border-t border-rule' if show_newsletter %>">
          <div class="font-mono text-[10px] uppercase tracking-[0.2em] text-sage-deep mb-3.5">Otherwise</div>
          <% [
            [ "Email", cms_setting.contact_email, "mailto:#{cms_setting.contact_email}" ],
            [ "RSS",   "/feed", "/feed" ]
          ].each_with_index do |(label, value, href), i| %>
            <a href="<%= href %>" class="flex justify-between py-2.5 font-mono text-[11px] <%= 'border-t border-rule' if i > 0 %> hover:text-sage-deep transition-colors group">
              <span class="text-gray-500"><%= label %></span>
              <span class="text-ink group-hover:text-sage-deep"><%= value %></span>
            </a>
          <% end %>
        </div>
      <% end %>
    </aside>
  <% end %>
</section>

<%# ─── LATEST STORIES FOOTER ───────────────────────────────────── %>
<% if defined?(@recent_articles) && @recent_articles.present? %>
  <% recent_total = Article.published.count rescue nil %>
  <section class="bg-cream-soft border-t border-rule lora">
    <div class="max-w-[1280px] mx-auto px-5 md:px-16 lg:px-20 pt-14 md:pt-16 pb-16 md:pb-20">

      <div class="flex items-baseline justify-between mb-9 pb-[18px] border-b-2 border-ink">
        <h2 class="font-serif font-medium text-2xl md:text-[30px] tracking-[-0.015em] text-ink m-0">
          Latest stories
        </h2>
        <%= link_to articles_path, class: "font-mono text-[10px] md:text-[11px] uppercase tracking-[0.18em] text-sage-deep hover:underline" do %>
          The archive →
        <% end %>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-10 gap-y-12">
        <% @recent_articles.each_with_index do |article, i| %>
          <% catalogue_number = recent_total ? recent_total - i : nil %>
          <%= link_to article_path(article), class: "block group" do %>
            <div class="flex justify-between items-baseline mb-3 font-mono text-[10px] uppercase tracking-[0.18em]">
              <% if catalogue_number %>
                <span class="text-sage-deep">No. <%= catalogue_number.to_s.rjust(3, "0") %></span>
              <% else %>
                <span></span>
              <% end %>
              <% if article.published_at %>
                <span class="text-gray-500"><%= article.published_at.strftime("%d %b %Y") %></span>
              <% end %>
            </div>

            <% if article.featured_image.attached? %>
              <%= image_tag article.featured_image.variant(:thumb),
                    class: "w-full aspect-[16/10] object-cover mb-3.5 bg-rule",
                    loading: "lazy", alt: article.title %>
            <% end %>

            <% if article.category.present? %>
              <div class="font-mono text-[10px] uppercase tracking-[0.18em] text-sage-deep mb-2">
                <%= article.category.name %>
              </div>
            <% end %>

            <h3 class="font-serif font-medium text-[20px] md:text-[22px] leading-[1.18] tracking-[-0.01em] text-ink m-0 mb-2.5 text-balance group-hover:text-sage-deep transition-colors">
              <%= article.title %>
            </h3>

            <% if article.tags.any? %>
              <div class="font-mono text-[10px] text-sage-deep">
                <%= article.tags.first(3).map { |t| t.name }.join(' / ').html_safe %>
              </div>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>
  </section>
<% end %>
