<% content_for :title, @title %>
<% content_for :head do %>
  <% set_meta_tags(
       title:     @title,
       canonical: url_for(only_path: false),
       og: { title: "#{@title} | #{site_name}", url: url_for(only_path: false) }
     ) %>
<% end %>

<article class="mx-auto max-w-[760px] px-5 md:px-8 pt-14 md:pt-24 pb-16 md:pb-24 lora">
  <header class="mb-10 md:mb-14 pb-7 border-b border-[#D9C4A6] dark:border-[#52300f]">
    <div class="font-mono text-[10px] md:text-[11px] uppercase tracking-[0.18em] text-[#704214] dark:text-[#D9C4A6] mb-4">
      <%= site_name %>
    </div>
    <h1 class="font-serif font-medium text-[40px] md:text-[64px] leading-[1.05] tracking-[-0.025em] text-[#423525] dark:text-gray-200 m-0 text-balance">
      <%= @title %>
    </h1>
  </header>

  <div class="page-prose font-serif text-[17px] md:text-[18px] leading-[1.7] text-[#423525] dark:text-gray-200 text-pretty">
    <%= @html %>
  </div>
</article>
