<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-serif text-sage-deep dark:text-peach">Categories</h1>
  <%= link_to "New Category", new_admin_category_path,
      class: "px-4 py-2 bg-sage-deep hover:bg-ink-soft text-white rounded text-sm transition-colors" %>
</div>

<div class="bg-white dark:bg-ink rounded-lg shadow overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-cream-soft dark:bg-ink-soft text-sage-deep dark:text-peach">
      <tr>
        <th class="text-left px-4 py-3 font-semibold">Name</th>
        <th class="text-left px-4 py-3 font-semibold">Parent</th>
        <th class="text-left px-4 py-3 font-semibold">Status</th>
        <th class="text-left px-4 py-3 font-semibold">Created</th>
        <th class="text-left px-4 py-3 font-semibold">Updated</th>
        <th class="text-right px-4 py-3 font-semibold">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
      <% @categories.each do |category| %>
        <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
          <td class="px-4 py-3 font-medium text-gray-900 dark:text-gray-100">
            <%= category.name %>
          </td>
          <td class="px-4 py-3 text-gray-500 dark:text-gray-400 text-xs">
            <%= category.parent&.name || "—" %>
          </td>
          <td class="px-4 py-3">
            <span class="px-2 py-0.5 rounded text-xs font-medium
              <%= category.active? ? 'bg-green-100 text-green-800 dark:bg-green-900/40 dark:text-green-300'
                                   : 'bg-gray-100 text-gray-600 dark:bg-ink-soft dark:text-gray-400' %>">
              <%= category.status&.humanize || "—" %>
            </span>
          </td>
          <td class="px-4 py-3 text-gray-500 dark:text-gray-400 text-xs whitespace-nowrap">
            <%= category.created_at.strftime("%b %-d, %Y") %>
          </td>
          <td class="px-4 py-3 text-gray-500 dark:text-gray-400 text-xs whitespace-nowrap">
            <%= category.updated_at.strftime("%b %-d, %Y") %>
          </td>
          <td class="px-4 py-3 text-right">
            <div class="flex items-center justify-end gap-2">
              <%= link_to "Edit", edit_admin_category_path(category),
                  class: "px-2 py-1 text-xs border border-sage-deep text-sage-deep
                          dark:border-peach dark:text-peach rounded hover:bg-peach-tint
                          dark:hover:bg-sage-deep/20 transition-colors" %>

              <button type="button"
                      class="px-2 py-1 text-xs bg-red-600 hover:bg-red-700 text-white rounded transition-colors cursor-pointer"
                      data-controller="admin-modal"
                      data-action="click->admin-modal#open"
                      data-admin-modal-url-value="<%= admin_category_path(category) %>"
                      data-admin-modal-title-value="Delete &ldquo;<%= category.name %>&rdquo;?">
                Delete
              </button>
            </div>
          </td>
        </tr>
      <% end %>

      <% if @categories.empty? %>
        <tr>
          <td colspan="6" class="px-4 py-8 text-center text-gray-400 dark:text-gray-500">
            No categories yet.
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="mt-6 flex justify-center">
  <%= paginate @categories %>
</div>

<%= render "admin/shared/confirm_modal" %>
