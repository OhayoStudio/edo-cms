<%= form_with model: [:admin, category], class: "space-y-6" do |f| %>
  <% if category.errors.any? %>
    <div class="bg-red-50 dark:bg-red-900/20 border border-red-300 dark:border-red-700 rounded-lg p-4">
      <p class="text-sm font-medium text-red-800 dark:text-red-300 mb-2">
        <%= pluralize(category.errors.count, "error") %> prevented this category from being saved:
      </p>
      <ul class="list-disc list-inside text-sm text-red-700 dark:text-red-400 space-y-1">
        <% category.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <%= f.label :name, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.text_field :name,
          class: "block w-full rounded border px-3 py-2 text-sm bg-white dark:bg-ink-soft
                  text-gray-900 dark:text-gray-100
                  #{category.errors[:name].any? ? 'border-red-400 focus:outline-red-500' : 'border-gray-300 dark:border-gray-600 focus:outline-sage-deep'}" %>
    </div>

    <div>
      <%= f.label :parent_id, "Parent category", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.collection_select :parent_id,
          Category.where.not(id: category.id).order(:name), :id, :name,
          { include_blank: "— None (root category) —" },
          class: "block w-full rounded border px-3 py-2 text-sm bg-white dark:bg-ink-soft
                  text-gray-900 dark:text-gray-100 border-gray-300 dark:border-gray-600" %>
    </div>

    <div class="md:col-span-2">
      <%= f.label :description, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.text_area :description, rows: 3,
          class: "block w-full rounded border px-3 py-2 text-sm bg-white dark:bg-ink-soft
                  text-gray-900 dark:text-gray-100
                  #{category.errors[:description].any? ? 'border-red-400 focus:outline-red-500' : 'border-gray-300 dark:border-gray-600 focus:outline-sage-deep'}" %>
    </div>

    <div>
      <%= f.label :meta_title, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.text_field :meta_title,
          class: "block w-full rounded border px-3 py-2 text-sm bg-white dark:bg-ink-soft
                  text-gray-900 dark:text-gray-100 border-gray-300 dark:border-gray-600 focus:outline-sage-deep" %>
      <p class="mt-1 text-xs text-gray-400">Max 60 characters</p>
    </div>

    <div>
      <%= f.label :meta_description, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.text_field :meta_description,
          class: "block w-full rounded border px-3 py-2 text-sm bg-white dark:bg-ink-soft
                  text-gray-900 dark:text-gray-100 border-gray-300 dark:border-gray-600 focus:outline-sage-deep" %>
      <p class="mt-1 text-xs text-gray-400">Max 160 characters</p>
    </div>

    <div>
      <%= f.label :status, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.select :status, Category.statuses.keys.map { |s| [s.humanize, s] },
          {},
          class: "block w-full rounded border px-3 py-2 text-sm bg-white dark:bg-ink-soft
                  text-gray-900 dark:text-gray-100 border-gray-300 dark:border-gray-600" %>
    </div>

    <div class="flex items-center gap-2 pt-5">
      <%= f.check_box :featured, class: "rounded border-gray-300 text-sage-deep" %>
      <%= f.label :featured, "Featured category", class: "text-sm text-gray-700 dark:text-gray-300" %>
    </div>
  </div>

  <div class="flex items-center gap-4 pt-2">
    <%= f.submit category.persisted? ? "Update Category" : "Create Category",
        class: "px-5 py-2 bg-sage-deep hover:bg-ink-soft text-white rounded text-sm transition-colors cursor-pointer" %>
    <%= link_to "Cancel", admin_categories_path,
        class: "px-5 py-2 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300
                rounded text-sm hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors" %>
  </div>
<% end %>
