<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-serif text-sage-deep dark:text-peach">Videos</h1>
  <%= link_to "New Video", new_admin_video_path,
      class: "px-4 py-2 bg-sage-deep hover:bg-ink-soft text-white rounded text-sm transition-colors" %>
</div>

<div class="bg-white dark:bg-ink rounded-lg shadow overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-cream-soft dark:bg-ink-soft text-sage-deep dark:text-peach">
      <tr>
        <th class="text-left px-4 py-3 font-semibold">Title</th>
        <th class="text-left px-4 py-3 font-semibold">
          <%= select_tag :status,
                options_for_select(
                  [["All statuses", ""], ["Published", "published"], ["Unpublished", "unpublished"]],
                  params[:status].presence || ""
                ),
                onchange: "window.location = '#{admin_videos_path}?status=' + this.value",
                class: "text-xs font-semibold bg-transparent border-0 text-sage-deep dark:text-peach
                        cursor-pointer focus:outline-none pr-1 -ml-1" %>
        </th>
        <th class="text-left px-4 py-3 font-semibold">Created</th>
        <th class="text-left px-4 py-3 font-semibold">Updated</th>
        <th class="text-right px-4 py-3 font-semibold">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
      <% @videos.each do |video| %>
        <tr id="video-row-<%= video.id %>" class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors">
          <td class="px-4 py-3 font-medium text-gray-900 dark:text-gray-100 max-w-xs truncate">
            <%= video.title %>
          </td>
          <td class="px-4 py-3">
            <% published = video.story&.is_published %>
            <span class="px-2 py-0.5 rounded text-xs font-medium
              <%= published ? 'bg-green-100 text-green-800 dark:bg-green-900/40 dark:text-green-300'
                            : 'bg-peach-soft text-sage-deep dark:bg-sage-deep/40 dark:text-peach' %>">
              <%= published ? "Published" : "Unpublished" %>
            </span>
          </td>
          <td class="px-4 py-3 text-gray-500 dark:text-gray-400 text-xs whitespace-nowrap">
            <%= video.created_at.strftime("%b %-d, %Y") %>
          </td>
          <td class="px-4 py-3 text-gray-500 dark:text-gray-400 text-xs whitespace-nowrap">
            <%= video.updated_at.strftime("%b %-d, %Y") %>
          </td>
          <td class="px-4 py-3 text-right">
            <div class="flex items-center justify-end gap-2">
              <%= link_to "Edit", edit_admin_video_path(video),
                  class: "px-2 py-1 text-xs border border-sage-deep text-sage-deep
                          dark:border-peach dark:text-peach rounded hover:bg-peach-tint
                          dark:hover:bg-sage-deep/20 transition-colors" %>

              <% if video.story&.is_published %>
                <%= button_to "Unpublish", unpublish_admin_video_path(video), method: :patch,
                    class: "px-2 py-1 text-xs border border-gray-400 text-gray-600
                            dark:border-gray-500 dark:text-gray-300 rounded hover:bg-gray-100
                            dark:hover:bg-gray-700 transition-colors cursor-pointer" %>
              <% else %>
                <%= button_to "Publish", publish_admin_video_path(video), method: :patch,
                    class: "px-2 py-1 text-xs bg-green-600 hover:bg-green-700 text-white rounded transition-colors cursor-pointer" %>
              <% end %>

              <button type="button"
                      class="px-2 py-1 text-xs bg-red-600 hover:bg-red-700 text-white rounded transition-colors cursor-pointer"
                      data-controller="admin-modal"
                      data-action="click->admin-modal#open"
                      data-admin-modal-url-value="<%= admin_video_path(video) %>"
                      data-admin-modal-title-value="Delete &ldquo;<%= video.title %>&rdquo;?">
                Delete
              </button>
            </div>
          </td>
        </tr>
      <% end %>

      <% if @videos.empty? %>
        <tr>
          <td colspan="5" class="px-4 py-8 text-center text-gray-400 dark:text-gray-500">
            No videos yet.
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="mt-6 flex justify-center">
  <%= paginate @videos, params: { status: params[:status] } %>
</div>

<%= render "admin/shared/confirm_modal" %>
