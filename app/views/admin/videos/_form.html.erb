<%= form_with model: [:admin, video], class: "space-y-6",
    data: { controller: "youtube-thumbnail",
            "youtube-thumbnail-metadata-url-value": metadata_admin_videos_path } do |f| %>
  <% if video.errors.any? %>
    <div class="bg-red-50 dark:bg-red-900/20 border border-red-300 dark:border-red-700 rounded-lg p-4">
      <p class="text-sm font-medium text-red-800 dark:text-red-300 mb-2">
        <%= pluralize(video.errors.count, "error") %> prevented this video from being saved:
      </p>
      <ul class="list-disc list-inside text-sm text-red-700 dark:text-red-400 space-y-1">
        <% video.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-4">
    <div>
      <%= f.label :title, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.text_field :title,
          data: { "youtube-thumbnail-target": "titleInput" },
          class: "block w-full rounded border px-3 py-2 text-sm bg-white dark:bg-gray-700
                  text-gray-900 dark:text-gray-100
                  #{video.errors[:title].any? ? 'border-red-400 focus:outline-red-500' : 'border-gray-300 dark:border-gray-600 focus:outline-[#704214]'}" %>
    </div>

    <div>
      <%= f.label :url, "Video URL (YouTube)", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.url_field :url,
          placeholder: "https://www.youtube.com/watch?v=...",
          data: { "youtube-thumbnail-target": "urlInput" },
          class: "block w-full rounded border px-3 py-2 text-sm bg-white dark:bg-gray-700
                  text-gray-900 dark:text-gray-100
                  #{video.errors[:url].any? ? 'border-red-400 focus:outline-red-500' : 'border-gray-300 dark:border-gray-600 focus:outline-[#704214]'}" %>
    </div>

    <div>
      <%= f.label :description, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.text_area :description, rows: 4,
          data: { "youtube-thumbnail-target": "descriptionInput" },
          class: "block w-full rounded border px-3 py-2 text-sm bg-white dark:bg-gray-700
                  text-gray-900 dark:text-gray-100
                  #{video.errors[:description].any? ? 'border-red-400 focus:outline-red-500' : 'border-gray-300 dark:border-gray-600 focus:outline-[#704214]'}" %>
    </div>

    <div>
      <%= f.hidden_field :use_youtube_thumbnail, value: "0",
          data: { "youtube-thumbnail-target": "flag" } %>

      <%= f.label :featured_image, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <% if video.persisted? && video.featured_image.attached? %>
        <div class="mb-2">
          <%= image_tag video.featured_image.variant(resize_to_limit: [200, 120]),
              data: { "video-thumbnail-enhance-target": "featuredPreview" },
              class: "rounded border border-gray-200 dark:border-gray-600" %>
          <p class="text-xs text-gray-400 mt-1">Current thumbnail — upload a new file to replace it</p>
        </div>
      <% end %>
      <div>
        <%= f.file_field :featured_image, accept: "image/*",
            required: !video.featured_image.attached?,
            data: { "youtube-thumbnail-target": "fileInput" },
            class: "block w-full text-sm text-gray-500 dark:text-gray-400
                    file:mr-3 file:py-1.5 file:px-3 file:rounded file:border-0
                    file:text-xs file:bg-[#704214] file:text-white hover:file:bg-[#52300f]" %>
        <button type="button"
            data-youtube-thumbnail-target="useButton"
            data-action="click->youtube-thumbnail#use"
            class="hidden mt-2 px-3 py-1.5 text-xs rounded border border-[#704214] text-[#704214]
                   dark:text-[#D9C4A6] dark:border-[#D9C4A6] hover:bg-[#704214] hover:text-white
                   dark:hover:bg-[#704214] transition-colors">
          Use YouTube thumbnail
        </button>
        <img src="" alt="YouTube thumbnail preview"
             data-youtube-thumbnail-target="preview"
             class="hidden mt-2 rounded border border-gray-200 dark:border-gray-600 w-40">
      </div>
    </div>
  </div>

  <%# ── AI Thumbnail Enhancement ──────────────────────────────────────────── %>
  <% if video.persisted? && video.featured_image.attached? %>
    <div class="space-y-3 mt-4"
         data-controller="video-thumbnail-enhance"
         data-video-thumbnail-enhance-enhance-url-value="<%= ai_enhance_thumbnail_admin_video_path(video) %>"
         data-video-thumbnail-enhance-promote-url-value="<%= promote_candidate_thumbnail_admin_video_path(video) %>"
         data-video-thumbnail-enhance-destroy-url-value="<%= destroy_candidate_thumbnail_admin_video_path(video) %>">

      <p class="text-sm font-medium text-gray-700 dark:text-gray-300">AI Enhance Thumbnail</p>

      <textarea data-video-thumbnail-enhance-target="prompt" rows="2"
                class="block w-full rounded border border-gray-300 dark:border-gray-600 px-3 py-2 text-sm
                       bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100
                       focus:outline-[#704214] resize-none"><%= Admin::VideosController::DEFAULT_ENHANCE_PROMPT %></textarea>

      <div class="flex items-center gap-3">
        <button type="button"
                data-action="click->video-thumbnail-enhance#enhance"
                data-video-thumbnail-enhance-target="enhanceBtn"
                class="px-3 py-1.5 text-xs bg-[#704214] hover:bg-[#52300f] text-white rounded transition-colors">
          <span data-video-thumbnail-enhance-target="icon" class="inline-block">✦</span> AI enhance thumbnail
        </button>
        <span data-video-thumbnail-enhance-target="status" class="text-xs text-gray-400"></span>
      </div>

      <%# Existing candidate thumbnails %>
      <div data-video-thumbnail-enhance-target="grid" class="flex flex-wrap gap-2">
        <% video.candidate_thumbnails.each do |ct| %>
          <% next unless ct.blob.variable? %>
          <div class="relative group" data-attachment-id="<%= ct.id %>">
            <%= image_tag ct.variant(resize_to_limit: [ 160, 90 ]),
                class: "w-40 h-[90px] object-cover rounded border border-gray-200 dark:border-gray-600" %>
            <button type="button"
                    data-action="click->video-thumbnail-enhance#destroy"
                    class="absolute -top-1.5 -right-1.5 w-5 h-5 bg-red-500 hover:bg-red-600 text-white
                           rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100
                           transition-opacity shadow text-xs font-bold"
                    title="Delete">✕</button>
            <button type="button"
                    data-action="click->video-thumbnail-enhance#promote"
                    class="absolute bottom-1 left-1 right-1 text-xs bg-black/60 hover:bg-black/80 text-white
                           rounded py-0.5 text-center opacity-0 group-hover:opacity-100 transition-opacity">
              Set as Featured
            </button>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
  <%# ── /AI Thumbnail Enhancement ─────────────────────────────────────────── %>

  <div class="flex items-center gap-4 pt-2">
    <%= f.submit video.persisted? ? "Update Video" : "Create Video",
        class: "px-5 py-2 bg-[#704214] hover:bg-[#52300f] text-white rounded text-sm transition-colors cursor-pointer" %>
    <%= link_to "Cancel", admin_videos_path,
        class: "px-5 py-2 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300
                rounded text-sm hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors" %>
  </div>
<% end %>
