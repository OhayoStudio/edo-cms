<% content_for :title, "Edit Panoramic Image" %>

<div class="w-full max-w-2xl">
  <div class="mb-8">
    <%= link_to "← Back to panoramic images", admin_panoramic_images_path, class: "text-[#704214] dark:text-amber-400 hover:underline" %>
  </div>

  <h1 class="font-bold text-4xl mb-8">Edit Panoramic Image</h1>

  <%= render "form", panoramic_image: @panoramic_image %>

  <div class="mt-8">
    <%= link_to "View", admin_panoramic_image_path(@panoramic_image),
        class: "inline-block px-4 py-2 bg-gray-100 dark:bg-gray-700 text-gray-900 dark:text-gray-100 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600" %>
  </div>
</div>
