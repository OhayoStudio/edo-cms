<%= form_with(model: [ :admin, @panoramic_image ], class: "space-y-6") do |form| %>
  <% if @panoramic_image.errors.any? %>
    <div class="bg-red-50 dark:bg-red-900/20 border border-red-300 dark:border-red-700 rounded-lg p-4">
      <p class="text-sm font-medium text-red-800 dark:text-red-300 mb-2">
        <%= pluralize(@panoramic_image.errors.count, "error") %> prevented this from being saved:
      </p>
      <ul class="list-disc list-inside text-sm text-red-700 dark:text-red-400">
        <% @panoramic_image.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :image, "Image", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
    <% if @panoramic_image.image.attached? %>
      <div class="mb-4">
        <%= image_tag @panoramic_image.image, alt: "Preview", class: "max-w-xs h-auto rounded" %>
        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400"><%= @panoramic_image.image.filename %></p>
      </div>
    <% end %>
    <%= form.file_field :image,
        accept: "image/*",
        class: "block w-full text-sm text-gray-900 dark:text-gray-100 border border-gray-300 dark:border-gray-600 rounded-lg p-2.5" %>
  </div>

  <%= form.submit "Save Panoramic Image",
      class: "px-4 py-2 bg-[#704214] hover:bg-[#8b5a2b] text-white rounded-lg font-medium" %>
<% end %>
