<%= form_with model: [:admin, author], class: "space-y-6" do |f| %>
  <% if author.errors.any? %>
    <div class="bg-red-50 dark:bg-red-900/20 border border-red-300 dark:border-red-700 rounded-lg p-4">
      <p class="text-sm font-medium text-red-800 dark:text-red-300 mb-2">
        <%= pluralize(author.errors.count, "error") %> prevented this author from being saved:
      </p>
      <ul class="list-disc list-inside text-sm text-red-700 dark:text-red-400 space-y-1">
        <% author.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <%= f.label :first_name, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.text_field :first_name,
          class: "block w-full rounded border px-3 py-2 text-sm bg-white dark:bg-ink-soft
                  text-gray-900 dark:text-gray-100
                  #{author.errors[:first_name].any? ? 'border-red-400 focus:outline-red-500' : 'border-gray-300 dark:border-gray-600 focus:outline-sage-deep'}" %>
    </div>

    <div>
      <%= f.label :last_name, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.text_field :last_name,
          class: "block w-full rounded border px-3 py-2 text-sm bg-white dark:bg-ink-soft
                  text-gray-900 dark:text-gray-100
                  #{author.errors[:last_name].any? ? 'border-red-400 focus:outline-red-500' : 'border-gray-300 dark:border-gray-600 focus:outline-sage-deep'}" %>
    </div>

    <div>
      <%= f.label :email, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.email_field :email,
          class: "block w-full rounded border px-3 py-2 text-sm bg-white dark:bg-ink-soft
                  text-gray-900 dark:text-gray-100
                  #{author.errors[:email].any? ? 'border-red-400 focus:outline-red-500' : 'border-gray-300 dark:border-gray-600 focus:outline-sage-deep'}" %>
    </div>

    <div>
      <%= f.label :website, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.url_field :website, placeholder: "https://",
          class: "block w-full rounded border px-3 py-2 text-sm bg-white dark:bg-ink-soft
                  text-gray-900 dark:text-gray-100 border-gray-300 dark:border-gray-600 focus:outline-sage-deep" %>
    </div>

    <div>
      <%= f.label :role, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.select :role, Author.roles.keys.map { |r| [ r.humanize, r ] },
          { include_blank: false },
          class: "block w-full rounded border px-3 py-2 text-sm bg-white dark:bg-ink-soft
                  text-gray-900 dark:text-gray-100 border-gray-300 dark:border-gray-600" %>
    </div>

    <div>
      <%= f.label :status, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.select :status, Author.statuses.keys.map { |s| [ s.humanize, s ] },
          { include_blank: false },
          class: "block w-full rounded border px-3 py-2 text-sm bg-white dark:bg-ink-soft
                  text-gray-900 dark:text-gray-100 border-gray-300 dark:border-gray-600" %>
    </div>

    <div>
      <%= f.label :twitter_handle, "Twitter / X", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.text_field :twitter_handle, placeholder: "@handle",
          class: "block w-full rounded border px-3 py-2 text-sm bg-white dark:bg-ink-soft
                  text-gray-900 dark:text-gray-100 border-gray-300 dark:border-gray-600 focus:outline-sage-deep" %>
    </div>

    <div>
      <%= f.label :github_username, "GitHub", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.text_field :github_username, placeholder: "username",
          class: "block w-full rounded border px-3 py-2 text-sm bg-white dark:bg-ink-soft
                  text-gray-900 dark:text-gray-100 border-gray-300 dark:border-gray-600 focus:outline-sage-deep" %>
    </div>

    <div class="md:col-span-2">
      <%= f.label :linkedin_url, "LinkedIn", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.url_field :linkedin_url, placeholder: "https://linkedin.com/in/",
          class: "block w-full rounded border px-3 py-2 text-sm bg-white dark:bg-ink-soft
                  text-gray-900 dark:text-gray-100 border-gray-300 dark:border-gray-600 focus:outline-sage-deep" %>
    </div>

    <div class="md:col-span-2">
      <%= f.label :bio, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.text_area :bio, rows: 4,
          class: "block w-full rounded border px-3 py-2 text-sm bg-white dark:bg-ink-soft
                  text-gray-900 dark:text-gray-100 border-gray-300 dark:border-gray-600 focus:outline-sage-deep" %>
    </div>

    <div>
      <%= f.label :avatar, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" %>
      <% if author.persisted? && author.avatar.attached? %>
        <img src="<%= url_for(author.avatar.variant(:thumb)) %>"
             class="w-16 h-16 rounded-full object-cover border border-gray-200 dark:border-gray-600 mb-2" />
      <% end %>
      <%= f.file_field :avatar, accept: "image/*",
          class: "block w-full text-sm text-gray-500 dark:text-gray-400
                  file:mr-3 file:py-1.5 file:px-3 file:rounded file:border-0
                  file:text-xs file:bg-sage-deep file:text-white hover:file:bg-ink-soft" %>
    </div>
  </div>

  <div class="flex items-center gap-4 pt-2">
    <%= f.submit author.persisted? ? "Update Author" : "Create Author",
        class: "px-5 py-2 bg-sage-deep hover:bg-ink-soft text-white rounded text-sm transition-colors cursor-pointer" %>
    <%= link_to "Cancel", admin_authors_path,
        class: "px-5 py-2 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300
                rounded text-sm hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors" %>
  </div>
<% end %>
