<%# Modal subtree for inserting panoramic images into the Lexxy editor.
    Rendered inside an element scoped with data-controller="panoramic-images". %>
<div data-panoramic-images-target="modal"
     class="hidden fixed inset-0 z-50 overflow-y-auto">
  <div class="flex items-center justify-center min-h-screen p-4">
    <div data-action="click->panoramic-images#close"
         class="fixed inset-0 bg-gray-900/75"></div>

    <div class="relative bg-white dark:bg-gray-800 rounded-lg shadow-xl w-full max-w-md">
      <div class="px-5 py-4 border-b border-gray-200 dark:border-gray-700 flex justify-between items-center">
        <h3 class="text-base font-medium text-gray-900 dark:text-gray-100">
          Insert Panoramic Image
        </h3>
        <button type="button"
                data-action="click->panoramic-images#close"
                class="text-gray-400 hover:text-gray-600 text-xl leading-none">×</button>
      </div>

      <div class="p-4 max-h-[60vh] overflow-y-auto" data-panoramic-images-target="content">
        <p class="text-sm text-gray-500 dark:text-gray-400 text-center py-8">Loading…</p>
      </div>

      <div class="px-5 py-3 border-t border-gray-200 dark:border-gray-700 flex justify-between items-center">
        <button type="button"
                data-action="click->panoramic-images#prevPage"
                data-panoramic-images-target="prevBtn"
                class="px-3 py-1 text-xs bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded hover:bg-gray-200 disabled:opacity-40 disabled:cursor-not-allowed">
          ← Previous
        </button>
        <span class="text-xs text-gray-600 dark:text-gray-400" data-panoramic-images-target="pageInfo">Page 1</span>
        <button type="button"
                data-action="click->panoramic-images#nextPage"
                data-panoramic-images-target="nextBtn"
                class="px-3 py-1 text-xs bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded hover:bg-gray-200 disabled:opacity-40 disabled:cursor-not-allowed">
          Next →
        </button>
      </div>
    </div>
  </div>
</div>
