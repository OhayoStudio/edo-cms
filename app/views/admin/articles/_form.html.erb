<%= form_with model: [:admin, article], class: "space-y-6" do |f| %>
  <% if article.errors.any? %>
    <div class="bg-red-50 dark:bg-red-900/20 border border-red-300 dark:border-red-700 rounded-lg p-4">
      <p class="text-sm font-medium text-red-800 dark:text-red-300 mb-2">
        <%= pluralize(article.errors.count, "error") %> prevented this article from being saved:
      </p>
      <ul class="list-disc list-inside text-sm text-red-700 dark:text-red-400 space-y-1">
        <% article.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="md:col-span-2">
      <%= f.label :title, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.text_field :title,
          class: "block w-full rounded border px-3 py-2 text-sm bg-white dark:bg-gray-700
                  text-gray-900 dark:text-gray-100
                  #{article.errors[:title].any? ? 'border-red-400 focus:outline-red-500' : 'border-gray-300 dark:border-gray-600 focus:outline-[#704214]'}" %>
    </div>

    <div class="md:col-span-2">
      <%= f.label :subtitle, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.text_field :subtitle,
          class: "block w-full rounded border px-3 py-2 text-sm bg-white dark:bg-gray-700
                  text-gray-900 dark:text-gray-100 border-gray-300 dark:border-gray-600 focus:outline-[#704214]" %>
    </div>

    <div>
      <%= f.label :author_id, "Author", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.collection_select :author_id, Author.not_deleted.order(:first_name), :id, :display_name,
          { include_blank: "— Select author —" },
          class: "block w-full rounded border px-3 py-2 text-sm bg-white dark:bg-gray-700
                  text-gray-900 dark:text-gray-100
                  #{article.errors[:author_id].any? ? 'border-red-400' : 'border-gray-300 dark:border-gray-600'}" %>
    </div>

    <div>
      <%= f.label :category_id, "Category", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.collection_select :category_id, Category.not_deleted.order(:name), :id, :name,
          { include_blank: "— Select category —" },
          class: "block w-full rounded border px-3 py-2 text-sm bg-white dark:bg-gray-700
                  text-gray-900 dark:text-gray-100
                  #{article.errors[:category_id].any? ? 'border-red-400' : 'border-gray-300 dark:border-gray-600'}" %>
    </div>

    <div>
      <%= f.label :status, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.select :status, Article.statuses.keys.map { |s| [s.humanize, s] },
          { include_blank: false },
          class: "block w-full rounded border px-3 py-2 text-sm bg-white dark:bg-gray-700
                  text-gray-900 dark:text-gray-100 border-gray-300 dark:border-gray-600" %>
    </div>

    <div>
      <%= f.label :reading_time, "Reading time (min)", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.number_field :reading_time, min: 1,
          class: "block w-full rounded border px-3 py-2 text-sm bg-white dark:bg-gray-700
                  text-gray-900 dark:text-gray-100 border-gray-300 dark:border-gray-600 focus:outline-[#704214]" %>
      <p class="mt-1 text-xs text-gray-400">Auto-calculated on save</p>
    </div>

    <div>
      <%= f.label :published_at, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.datetime_local_field :published_at,
          value: article.published_at&.strftime("%Y-%m-%dT%H:%M"),
          class: "block w-full rounded border px-3 py-2 text-sm bg-white dark:bg-gray-700
                  text-gray-900 dark:text-gray-100 border-gray-300 dark:border-gray-600" %>
    </div>

    <div class="md:col-span-2">
      <%= f.label :excerpt, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.text_area :excerpt, rows: 3,
          class: "block w-full rounded border px-3 py-2 text-sm bg-white dark:bg-gray-700
                  text-gray-900 dark:text-gray-100 border-gray-300 dark:border-gray-600 focus:outline-[#704214]" %>
      <p class="mt-1 text-xs text-gray-400">Max 150 characters</p>
    </div>

    <div class="md:col-span-2 sticky top-4 z-10 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 p-3 shadow-sm"
         data-controller="article-photo-candidates google-photos"
         data-article-id="<%= @article.id %>"
         data-google-photos-client-id-value="<%= ENV.fetch('GOOGLE_CLIENT_ID') %>"
         data-google-photos-api-key-value="<%= ENV.fetch('GOOGLE_API_KEY') %>"
         data-google-photos-import-url-value="<%= admin_google_photos_import_path %>"
         data-google-photos-article-id-value="<%= @article.id %>">
      <div class="flex items-center justify-between mb-2">
        <%= f.label :photo_candidates, "Photos — drag into content or click to insert at cursor", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
        <button type="button"
                data-action="click->google-photos#open"
                class="flex items-center gap-1 px-2 py-1 text-xs border border-gray-300 dark:border-gray-600 text-gray-600 dark:text-gray-300 rounded hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          Google Photos
        </button>
      </div>
      <div data-article-photo-candidates-target="previews" class="flex flex-wrap gap-2 mb-2">
        <% if @article.photo_candidates.attached? %>
          <% @article.photo_candidates.each do |photo| %>
            <div class="relative m-1 group" data-attachment-id="<%= photo.id %>">
              <img src="<%= url_for(photo.variant(resize_to_limit: [96,96])) %>"
                   data-original-url="<%= url_for(photo) %>"
                   draggable="true"
                   data-action="dragstart->article-photo-candidates#onThumbnailDragStart click->article-photo-candidates#onThumbnailClick"
                   class="object-cover w-24 h-24 rounded border bg-white cursor-pointer hover:ring-2 hover:ring-[#704214]"
                   title="Click to insert at cursor · Drag to position" />
              <button type="button"
                      data-action="click->article-photo-candidates#deletePhoto"
                      class="absolute -top-1.5 -right-1.5 w-5 h-5 bg-red-500 hover:bg-red-600 text-white rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity shadow"
                      title="Delete photo">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              </button>
            </div>
          <% end %>
        <% end %>
      </div>
      <%= f.file_field :photo_candidates, multiple: true, class: "block w-full border-2 border-dashed border-gray-300 rounded-md p-3 text-center cursor-pointer bg-gray-50 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-400 text-sm", accept: "image/*", data: { action: "change->article-photo-candidates#uploadFiles", article_photo_candidates_target: "input" } %>
    </div>

    <div class="md:col-span-2">
      <%= f.label :content, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.lexxy_rich_text_area :content %>
    </div>

    <div class="md:col-span-2">
      <%= f.label :meta_description, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.text_area :meta_description, rows: 2,
          class: "block w-full rounded border px-3 py-2 text-sm bg-white dark:bg-gray-700
                  text-gray-900 dark:text-gray-100 border-gray-300 dark:border-gray-600 focus:outline-[#704214]" %>
      <p class="mt-1 text-xs text-gray-400">Max 160 characters</p>
    </div>

    <div class="md:col-span-2">
      <%= f.label :meta_keywords, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.text_field :meta_keywords,
          placeholder: "comma, separated, tags",
          class: "block w-full rounded border px-3 py-2 text-sm bg-white dark:bg-gray-700
                  text-gray-900 dark:text-gray-100 border-gray-300 dark:border-gray-600 focus:outline-[#704214]" %>
      <p class="mt-1 text-xs text-gray-400">Comma-separated — will be created as Tags automatically</p>
    </div>

    <div>
      <%= f.label :featured_image, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <% if article.persisted? && article.featured_image.attached? %>
        <div class="mb-2">
          <%= image_tag article.featured_image.variant(resize_to_limit: [200, 120]),
              class: "rounded border border-gray-200 dark:border-gray-600" %>
        </div>
      <% end %>
      <%= f.file_field :featured_image, accept: "image/*",
          class: "block w-full text-sm text-gray-500 dark:text-gray-400
                  file:mr-3 file:py-1.5 file:px-3 file:rounded file:border-0
                  file:text-xs file:bg-[#704214] file:text-white hover:file:bg-[#52300f]" %>
    </div>

    <div class="flex items-center gap-2 pt-5">
      <%= f.check_box :featured, class: "rounded border-gray-300 text-[#704214]" %>
      <%= f.label :featured, "Featured article", class: "text-sm text-gray-700 dark:text-gray-300" %>
    </div>
  </div>

  <div class="flex items-center gap-4 pt-2">
    <%= f.submit article.persisted? ? "Update Article" : "Create Article",
        class: "px-5 py-2 bg-[#704214] hover:bg-[#52300f] text-white rounded text-sm transition-colors cursor-pointer" %>
    <%= link_to "Cancel", admin_articles_path,
        class: "px-5 py-2 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300
                rounded text-sm hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors" %>
  </div>
<% end %>

