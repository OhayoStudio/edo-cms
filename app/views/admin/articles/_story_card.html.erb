<% return unless article.published? %>
<% image_blob =
  if article.featured_image.attached?
    article.featured_image.blob
  else
    article.content.embeds.find { |e| e.blob.image? }&.blob
  end %>
<% return unless image_blob %>

<div class="mt-6 pt-6 border-t border-gray-200 dark:border-gray-700"
     data-controller="story-preview"
     data-story-preview-download-url-value="<%= story_card_admin_article_path(article) %>"
     data-story-preview-image-url-value="<%= story_card_admin_article_path(article) %>"
     data-story-preview-video-url-value="<%= story_video_admin_article_path(article) %>"
     data-story-preview-share-url-value="<%= share_instagram_admin_article_path(article) %>">

  <h2 class="text-base font-semibold text-[#704214] dark:text-amber-200 mb-1">Instagram Story</h2>
  <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">Preview and position the image, then download or share directly to Instagram.</p>

  <button type="button"
          data-action="click->story-preview#open"
          class="inline-block text-sm font-medium text-white rounded px-4 py-2 transition-opacity hover:opacity-90"
          style="background: linear-gradient(to right, #833ab4, #fd1d1d, #fcb045);">
    Preview & Download Story Card
  </button>

  <%# ── Modal ───────────────────────────────────────────────────────────── %>
  <div data-story-preview-target="modal"
       data-action="click->story-preview#closeOnBackdrop"
       class="hidden fixed inset-0 z-50 bg-black/70 p-4"
       style="display:none;align-items:center;justify-content:center;">

    <div class="bg-white dark:bg-gray-900 rounded-xl shadow-2xl flex flex-col gap-4 p-5 max-h-screen overflow-y-auto" style="max-width:460px;width:100%">

      <div class="flex items-center justify-between">
        <h3 class="font-semibold text-gray-800 dark:text-gray-100">Position your image</h3>
        <button type="button" data-action="click->story-preview#close"
                class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 text-xl leading-none">&times;</button>
      </div>

      <%# 9:16 preview frame %>
      <div data-story-preview-target="frame"
           class="relative mx-auto overflow-hidden rounded-lg select-none"
           style="width:360px;height:640px;background:#111;">

        <img data-story-preview-target="image"
             src="<%= rails_blob_path(image_blob) %>"
             alt=""
             draggable="false"
             data-action="mousedown->story-preview#startDrag touchstart->story-preview#startDrag"
             class="absolute select-none"
             style="cursor:grab;user-select:none;-webkit-user-drag:none;max-width:none;">

        <%# Gradient overlay %>
        <div class="absolute inset-0 pointer-events-none"
             style="background:linear-gradient(to bottom, transparent 35%, rgba(0,0,0,0.88));"></div>

        <%# Text preview (approximate) %>
        <div class="absolute inset-x-0 bottom-0 pointer-events-none" style="padding:20px 28px 26px;">
          <% if article.category %>
            <p class="uppercase tracking-widest mb-2"
               style="font-size:11px;color:rgba(255,255,255,0.65);font-family:sans-serif;">
              <%= article.category.name %>
            </p>
          <% end %>
          <p class="leading-snug mb-2"
             style="font-size:24px;color:white;font-family:Georgia,serif;font-weight:bold;">
            <%= article.title %>
          </p>
          <% blurb = article.excerpt.presence || article.subtitle.presence %>
          <% if blurb %>
            <p style="font-size:13px;color:rgba(255,255,255,0.8);font-family:sans-serif;line-height:1.4;">
              <%= truncate(blurb, length: 90) %>
            </p>
          <% end %>
          <p class="mt-3" style="font-size:11px;color:rgba(255,255,255,0.45);font-family:sans-serif;">
            sepiabraun.com
          </p>
        </div>
      </div>

      <%# Zoom slider %>
      <div class="flex items-center gap-3">
        <span class="text-xs text-gray-500 dark:text-gray-400 shrink-0">Zoom</span>
        <input type="range" min="100" max="350" value="100" step="1"
               data-story-preview-target="zoom"
               data-action="input->story-preview#onZoom"
               class="w-full accent-[#704214]">
      </div>

      <%# Share status %>
      <div data-story-preview-target="shareStatus" class="hidden text-sm rounded-lg px-3 py-2"></div>

      <%# Actions %>
      <div class="flex gap-3 justify-end flex-wrap">
        <button type="button" data-action="click->story-preview#close"
                class="px-4 py-2 text-sm rounded border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800">
          Cancel
        </button>
        <button type="button"
                data-action="click->story-preview#download"
                data-story-preview-download-type="image"
                data-story-preview-image-url-value="<%= story_card_admin_article_path(article) %>"
                class="px-4 py-2 text-sm font-medium text-white rounded border border-white/20 hover:opacity-90 transition-opacity"
                style="background: linear-gradient(to right, #833ab4, #fd1d1d, #fcb045);">
          PNG (static)
        </button>
        <button type="button"
                data-action="click->story-preview#downloadVideo"
                data-story-preview-video-url-value="<%= story_video_admin_article_path(article) %>"
                class="px-4 py-2 text-sm font-medium text-white rounded border border-white/20 hover:opacity-90 transition-opacity"
                style="background: linear-gradient(to right, #833ab4, #fd1d1d, #fcb045);">
          MP4 (animated)
        </button>
        <button type="button"
                data-action="click->story-preview#shareImage"
                data-story-preview-target="shareImageBtn"
                class="px-4 py-2 text-sm font-medium text-white rounded border border-white/20 hover:opacity-90 transition-opacity"
                style="background: linear-gradient(to right, #833ab4, #fd1d1d, #fcb045);">
          Share PNG
        </button>
        <button type="button"
                data-action="click->story-preview#shareVideo"
                data-story-preview-target="shareVideoBtn"
                class="px-4 py-2 text-sm font-medium text-white rounded border border-white/20 hover:opacity-90 transition-opacity"
                style="background: linear-gradient(to right, #833ab4, #fd1d1d, #fcb045);">
          Share MP4
        </button>
      </div>

    </div>
  </div>
</div>
