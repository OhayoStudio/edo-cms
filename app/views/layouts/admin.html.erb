<!DOCTYPE html>
<html lang="en" class="edo-cms">
  <head>
    <title><%= content_for(:title) || "Admin — Edo CMS" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "lexxy" %>
    <%= javascript_importmap_tags %>
    <script>
      function applyTheme() {
        const theme = localStorage.getItem('theme') || 'light';
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
          document.documentElement.style.colorScheme = 'dark';
        } else {
          document.documentElement.classList.remove('dark');
          document.documentElement.style.colorScheme = 'light';
        }
      }
      applyTheme();
      document.addEventListener('turbo:load', applyTheme);
    </script>
  </head>

  <body class="edo-cms h-full bg-gray-200 dark:bg-gray-900 transition-colors duration-200"
        data-controller="dark-mode">

    <% if notice.present? %>
      <div class="fixed top-4 right-4 z-50 bg-green-100 border border-green-400 text-green-800
                  dark:bg-green-900 dark:border-green-600 dark:text-green-200
                  px-4 py-3 rounded shadow-md text-sm">
        <%= notice %>
      </div>
    <% end %>
    <% if alert.present? %>
      <div class="fixed top-4 right-4 z-50 bg-red-100 border border-red-400 text-red-800
                  dark:bg-red-900 dark:border-red-600 dark:text-red-200
                  px-4 py-3 rounded shadow-md text-sm">
        <%= alert %>
      </div>
    <% end %>

    <header class="bg-[#704214] dark:bg-[#281506] sticky top-0 z-40 shadow-md lora">
      <nav class="container mx-auto px-6 flex items-center justify-between h-14">
        <%= link_to "Admin", admin_root_path,
            class: "font-serif text-lg font-semibold tracking-wide text-white hover:text-amber-200 transition-colors" %>

        <ul class="flex items-center gap-1 text-sm font-medium">
          <li>
            <%= link_to "Articles", admin_articles_path,
                class: "px-3 py-2 rounded transition-colors #{controller_name == 'articles' ? 'bg-[#52300f] text-amber-200' : 'text-white hover:bg-[#52300f]'}" %>
          </li>
          <li>
            <%= link_to "Videos", admin_videos_path,
                class: "px-3 py-2 rounded transition-colors #{controller_name == 'videos' ? 'bg-[#52300f] text-amber-200' : 'text-white hover:bg-[#52300f]'}" %>
          </li>
          <li>
            <%= link_to "Categories", admin_categories_path,
                class: "px-3 py-2 rounded transition-colors #{controller_name == 'categories' ? 'bg-[#52300f] text-amber-200' : 'text-white hover:bg-[#52300f]'}" %>
          </li>
          <li>
            <%= link_to "Tags", admin_tags_path,
                class: "px-3 py-2 rounded transition-colors #{controller_name == 'tags' ? 'bg-[#52300f] text-amber-200' : 'text-white hover:bg-[#52300f]'}" %>
          </li>
          <li class="ml-2">
            <%= render "common/darkmode_toggle" %>
          </li>
          <li class="ml-2">
            <%= button_to "Logout", session_path, method: :delete,
                class: "px-3 py-1.5 rounded border border-white/40 hover:bg-white/10 text-white text-sm cursor-pointer transition-colors" %>
          </li>
        </ul>
      </nav>
    </header>

    <main class="container mx-auto px-6 py-8">
      <%= yield %>
    </main>
  </body>
</html>
