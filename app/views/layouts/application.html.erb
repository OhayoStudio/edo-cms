<!DOCTYPE html>
<html lang="en" class="sepiabraun">
  <head>
    <%= display_meta_tags(
          site:        "Sepia Braun",
          separator:   "|",
          description: MetaTagsHelper::DEFAULT_DESC,
          og:      { site_name: "Sepia Braun", type: "website" },
          twitter: { site: "@sepiabraun", card: "summary_large_image" }
        ) %>
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="sitemap" type="application/xml" href="/sitemaps/sitemap.xml.gz" />
    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%= tag.link rel: "manifest" , href: pwa_manifest_path(format: :json) %>
    <link rel="icon" href="/icon.png" type="image/png" />
    <link rel="icon" href="/icon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/icon.png" />
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "lexxy" %>
    <%= javascript_importmap_tags %>
    <script>
      // Prevent Flash Of Wrong Theme (FOWT) and ensure correct theme on Turbo navigation
      function applyTheme() {
        const theme = localStorage.getItem('theme') || 'light';
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
          document.documentElement.style.colorScheme = 'dark';
        } else {
          document.documentElement.classList.remove('dark');
          document.documentElement.style.colorScheme = 'light';
        }
      }
      applyTheme();
      document.addEventListener('turbo:load', applyTheme);
    </script>
  </head>

  <body class="sepiabraun h-full bg-gray-200 dark:bg-gray-800 transition-colors duration-200" data-controller="dark-mode">
    <header class="bg-gray-200 text-amber-900 dark:bg-slate-800 dark:text-[var(--color-accent)] hidden sm:block sticky top-0 z-50 lora ">      
      <nav aria-label="Main navigation" class="container px-16 mx-auto flex items-center justify-between">
        <a href="/" class="text-amber-900 dark:text-[var(--color-accent)] text-lg font-serif flex items-center">
          <%= image_tag "sepiabraun.svg", alt: "Sepia Braun", width: 80, height: 80, class: "w-20 h-20", style: "transform: scale(1.3);transform-origin: 50% 50%;transition: transform 0.3s ease;", id: "logo" %>
          <%= image_tag "sepia-clear.svg", alt: "Sepia Braun", width: 80, height: 80, class: "w-20 h-20", style: "transform: scale(1.3);transform-origin: 50% 50%;transition: transform 0.3s ease;", id: "logo-dark" %>
          <span class="ml-2 ">Sepia Braun</span>
        </a>

        <ul class="flex gap-8">
          <li class="p-6">
            <%= link_to "Stories", articles_path, class: "hover:text-amber-300 #{articles_section? ? 'text-amber-600' : ''}" %>
          </li>
          <li class="p-6">
            <%= link_to "Motion Pictures", videos_path, class: "hover:text-amber-300 #{current_page?(videos_path) ? 'text-amber-600' : ''}" %>
          </li>
          <li class="p-6">
            <a href="/about" class="hover:text-amber-300">About</a>
          </li>
          <li class="p-4">
            <%= render "common/darkmode_toggle" %>
          </li>
        </ul>
      </nav>
    </header>

    <!-- Mobile Header -->
    <div role="none" class="bg-gray-200 text-amber-900 dark:bg-slate-800 dark:text-[var(--color-accent)] block sm:hidden sticky top-0 z-50">
      <div class="flex items-center justify-between p-4">
        <div>
          <a href="/" class="text-amber-900 dark:text-[var(--color-accent)] text-lg font-serif flex items-center">
            <%= image_tag "sepiabraun.svg", alt: "Sepia Braun", width: 40, height: 40, class: "w-10 h-10", style: "transform: scale(1.3);transform-origin: 50% 50%;transition: transform 0.3s ease;", id: "logo-mobile" %>
            <%= image_tag "sepia-clear.svg", alt: "Sepia Braun", width: 40, height: 40, class: "w-10 h-10", style: "transform: scale(1.3);transform-origin: 50% 50%;transition: transform 0.3s ease;", id: "logo-mobile-dark" %>
            <span class="ml-2 ">Sepia Braun</span>
          </a>
        </div>
        <div class="flex items-center gap-2">
          <%= render "common/darkmode_toggle" %>
          <button id="hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu" class="text-amber-900 dark:text-[var(--color-accent)] focus:outline-none">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path>
            </svg>
          </button>
        </div>
      </div>
      <nav id="mobile-menu" aria-label="Mobile navigation" class="hidden">
        <ul class="flex gap-8">
          <li class="p-6">
            <%= link_to "Stories", articles_path, class: "text-amber-900 dark:text-[var(--color-accent)] hover:text-yellow-300 #{current_page?(articles_path) ? 'text-amber-900 dark:text-[var(--color-accent)]' : 'text-amber-600'}" %>
          </li>
          <li class="p-6">
            <%= link_to "Motion Pictures", videos_path, class: "text-amber-900 dark:text-[var(--color-accent)] hover:text-yellow-300 #{current_page?(videos_path) ? 'text-amber-900 dark:text-[var(--color-accent)]' : 'text-amber-600'}" %>
          </li>
          <li class="p-6">
            <a href="/about" class="text-amber-900 dark:text-[var(--color-accent)] hover:text-yellow-300">About</a>
          </li>
        </ul>
      </nav>
    </div>
    <main class="dark:bg-gray-800">
      <%= yield %>
    </main>
    <footer class="mt-24 lora border-t border-[#D9C4A6] dark:border-[#52300f] dark:bg-slate-800">
      <div class="container mx-auto px-6 py-12">

        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-8">

          <!-- Brand + copyright -->
          <div class="space-y-1">
            <p class="font-serif text-[#704214] dark:text-gray-300 tracking-wide">Sepia Braun</p>
            <p class="text-sm text-gray-500 dark:text-gray-300 italic">We have good taste, we are not uncertain ;-)</p>
            <p class="text-sm text-gray-500 dark:text-gray-300">&copy; 2025&ndash;<%= Time.current.year %></p>
          </div>

          <!-- Navigation links -->
          <nav aria-label="Footer navigation" class="flex flex-col sm:flex-row gap-4 sm:gap-8 text-sm text-gray-600 dark:text-gray-300">
            <%= link_to "Stories", articles_path,
                class: "hover:text-[#704214] dark:hover:text-amber-200 transition-colors" %>
            <%= link_to "Motion Pictures", videos_path,
                class: "hover:text-[#704214] dark:hover:text-amber-200 transition-colors" %>
            <%= link_to "About", about_path,
                class: "hover:text-[#704214] dark:hover:text-amber-200 transition-colors" %>
            <%= link_to "Colophon", colophon_path,
                class: "hover:text-[#704214] dark:hover:text-amber-200 transition-colors" %>
          </nav>

        </div>

      </div>
    </footer>
    <script>
      document.getElementById('hamburger').addEventListener('click', function() {
      var menu = document.getElementById('mobile-menu');
      var expanded = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      this.setAttribute('aria-expanded', String(!expanded));
      this.setAttribute('aria-label', expanded ? 'Open menu' : 'Close menu');
    });
    </script>
  </body>
</html>