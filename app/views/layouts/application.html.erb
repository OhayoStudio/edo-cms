<!DOCTYPE html>
<html lang="<%= I18n.locale %>" class="brand-theme">
  <head>
    <%= display_meta_tags(
          site:        site_name,
          separator:   "|",
          description: default_meta_description,
          og:      { site_name: site_name, type: "website" },
          twitter: { site: cms_setting.social_links["twitter"].presence, card: "summary_large_image" }.compact
        ) %>
    <% I18n.available_locales.each do |loc| %>
      <link rel="alternate" hreflang="<%= loc %>" href="<%= url_for(locale: loc, only_path: false) %>">
    <% end %>
    <link rel="alternate" hreflang="x-default" href="<%= url_for(locale: I18n.default_locale, only_path: false) %>">
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= cms_theme_style_tag %>
    <%= yield :head %>
    <link rel="sitemap" type="application/xml" href="/sitemaps/sitemap.xml.gz" />
    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%= tag.link rel: "manifest" , href: pwa_manifest_path(format: :json) %>
    <link rel="icon" href="/icon.png" type="image/png" />
    <link rel="icon" href="/icon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/icon.png" />
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "theme", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "lexxy" %>
    <%= javascript_importmap_tags %>
    <script>
      // Prevent Flash Of Wrong Theme (FOWT) and ensure correct theme on Turbo navigation
      function applyTheme() {
        const theme = localStorage.getItem('theme') || 'light';
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
          document.documentElement.style.colorScheme = 'dark';
        } else {
          document.documentElement.classList.remove('dark');
          document.documentElement.style.colorScheme = 'light';
        }
      }
      applyTheme();
      document.addEventListener('turbo:load', applyTheme);
    </script>
    <%= auto_discovery_link_tag :rss, feed_url(format: :rss), title: "#{site_name} RSS Feed" %>
    <% if Rails.env.production? && cms_setting.analytics_provider == "umami" && cms_setting.analytics_website_id.present? && cms_setting.analytics_host.present? %>
      <script defer src="https://<%= cms_setting.analytics_host %>/script.js"
              data-website-id="<%= cms_setting.analytics_website_id %>"></script>
    <% end %>
  </head>

  <body class="brand-theme h-full bg-gray-200 dark:bg-gray-800 transition-colors duration-200" data-controller="dark-mode">
    <header class="bg-gray-200 text-amber-900 dark:bg-slate-800 dark:text-[var(--color-accent)] hidden sm:block sticky top-0 z-50 lora">
      <nav aria-label="<%= t("nav.a11y.main_nav") %>" class="container px-16 mx-auto flex items-center justify-between">
        <a href="/" class="text-amber-900 dark:text-[var(--color-accent)] text-lg font-serif flex items-center gap-2 py-4">
          <% if cms_setting.logo_light.attached? %>
            <%= image_tag cms_setting.logo_light, alt: site_name, class: "h-16 w-auto block dark:hidden" %>
          <% end %>
          <% if cms_setting.logo_dark.attached? %>
            <%= image_tag cms_setting.logo_dark, alt: site_name, class: "h-16 w-auto hidden dark:block" %>
          <% end %>
          <span><%= site_name %></span>
        </a>

        <ul class="flex gap-8 items-center">
          <% cms_setting.primary_nav.each do |item| %>
            <li class="p-6">
              <%= link_to item["label"], item["path"], class: "hover:text-amber-300 #{current_page?(item['path']) ? 'text-amber-600' : ''}" %>
            </li>
          <% end %>
          <li class="p-2">
            <%= render "common/locale_switcher" %>
          </li>
          <li class="p-4">
            <%= render "common/darkmode_toggle" %>
          </li>
        </ul>
      </nav>
    </header>

    <!-- Mobile Header -->
    <div role="none" class="bg-gray-200 text-amber-900 dark:bg-slate-800 dark:text-[var(--color-accent)] block sm:hidden sticky top-0 z-50">
      <div class="flex items-center justify-between p-4">
        <div>
          <a href="/" class="text-amber-900 dark:text-[var(--color-accent)] text-lg font-serif flex items-center gap-2">
            <% if cms_setting.logo_light.attached? %>
              <%= image_tag cms_setting.logo_light, alt: site_name, class: "h-10 w-auto block dark:hidden" %>
            <% end %>
            <% if cms_setting.logo_dark.attached? %>
              <%= image_tag cms_setting.logo_dark, alt: site_name, class: "h-10 w-auto hidden dark:block" %>
            <% end %>
            <span><%= site_name %></span>
          </a>
        </div>
        <div class="flex items-center gap-2">
          <%= render "common/locale_switcher" %>
          <%= render "common/darkmode_toggle" %>
          <button id="hamburger" aria-label="<%= t("nav.a11y.open_menu") %>" aria-expanded="false" aria-controls="mobile-menu" class="text-amber-900 dark:text-[var(--color-accent)] focus:outline-none">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path>
            </svg>
          </button>
        </div>
      </div>
      <nav id="mobile-menu" aria-label="<%= t("nav.a11y.mobile_nav") %>" class="hidden">
        <ul class="flex flex-col">
          <% cms_setting.primary_nav.each do |item| %>
            <li class="p-6">
              <%= link_to item["label"], item["path"], class: "text-amber-900 dark:text-[var(--color-accent)] hover:text-yellow-300 #{current_page?(item['path']) ? 'text-amber-600' : ''}" %>
            </li>
          <% end %>
        </ul>
      </nav>
    </div>
    <main class="dark:bg-gray-800">
      <%= yield %>
    </main>
    <footer class="mt-24 lora border-t border-[#D9C4A6] dark:border-[#52300f] dark:bg-slate-800">
      <div class="container mx-auto px-6 py-12">
        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-8">
          <!-- Brand + copyright -->
          <div class="space-y-1">
            <p class="font-serif text-[#704214] dark:text-gray-300 tracking-wide"><%= site_name %></p>
            <% if cms_setting.tagline.present? %>
              <p class="text-sm text-gray-500 dark:text-gray-300 italic"><%= cms_setting.tagline %></p>
            <% end %>
            <p class="text-sm text-gray-500 dark:text-gray-300">&copy; <%= Time.current.year %></p>
          </div>

          <!-- Navigation links -->
          <nav aria-label="<%= t("nav.a11y.footer_nav") %>" class="flex flex-col sm:flex-row gap-4 sm:gap-8 text-sm text-gray-600 dark:text-gray-300">
            <% cms_setting.footer_nav.each do |item| %>
              <%= link_to item["label"], item["path"],
                    class: "hover:text-[#704214] dark:hover:text-amber-200 transition-colors" %>
            <% end %>
            <%= link_to t("nav.footer.rss"), feed_path(format: :rss),
                class: "hover:text-[#704214] dark:hover:text-amber-200 transition-colors" %>
          </nav>
        </div>
      </div>
    </footer>
    <script>
      (function() {
        var labels = { open: <%= raw t("nav.a11y.open_menu").to_json %>,
                       close: <%= raw t("nav.a11y.close_menu").to_json %> };
        document.getElementById('hamburger').addEventListener('click', function() {
          var menu = document.getElementById('mobile-menu');
          var expanded = !menu.classList.contains('hidden');
          menu.classList.toggle('hidden');
          this.setAttribute('aria-expanded', String(!expanded));
          this.setAttribute('aria-label', expanded ? labels.open : labels.close);
        });
      })();
    </script>
  </body>
</html>
