<%
  name = site_name
  description = default_meta_description
  theme = cms_color(:primary)
  background = cms_color(:background)
  icon_url = cms_favicon_url
%>{
  "name": <%= name.to_json %>,
  "icons": [
    {
      "src": <%= icon_url.to_json %>,
      "type": "image/png",
      "sizes": "512x512"
    },
    {
      "src": <%= icon_url.to_json %>,
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "maskable"
    }
  ],
  "start_url": "/",
  "display": "standalone",
  "scope": "/",
  "description": <%= description.to_json %>,
  "theme_color": <%= theme.to_json %>,
  "background_color": <%= background.to_json %>
}
