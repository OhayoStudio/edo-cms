<% content_for :head do %>
  <% page_title = @tag.meta_title.presence || @tag.name %>
  <% page_desc  = @tag.meta_description.presence || "Articles tagged #{@tag.name} on Sepia Braun." %>
  <% set_meta_tags(
       title:       page_title,
       description: page_desc,
       canonical:   tag_url(@tag),
       og: { title: page_title, url: tag_url(@tag), description: page_desc }
     ) %>
  <%= render "shared/json_ld", schema: {
        "@context"    => "https://schema.org",
        "@type"       => "CollectionPage",
        "name"        => page_title,
        "description" => page_desc,
        "url"         => tag_url(@tag),
        "isPartOf"    => { "@id" => "#{MetaTagsHelper::SITE_URL}/#website" }
      } %>
<% end %>

<div class="md:w-2/3 w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <h1 class="font-bold text-4xl">Showing tag</h1>

  <%= render @tag %>

  <%= link_to "Edit this tag", edit_tag_path(@tag), class: "mt-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
  <%= link_to "Back to tags", tags_path, class: "ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
  <div class="inline-block ml-2">
    <%= button_to "Destroy this tag", @tag, method: :delete, class: "mt-2 rounded-md px-3.5 py-2.5 text-white bg-red-600 hover:bg-red-500 font-medium" %>
  </div>
</div>
