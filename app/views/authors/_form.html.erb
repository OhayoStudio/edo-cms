<%= form_with(model: author, class: "contents") do |form| %>
  <% if author.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(author.errors.count, "error") %> prohibited this author from being saved:</h2>

      <ul class="list-disc ml-6">
        <% author.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :first_name %>
    <%= form.text_field :first_name, class: ["block shadow rounded-md border outline-none px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": author.errors[:first_name].none?, "border-red-400 focus:outline-red-600": author.errors[:first_name].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :last_name %>
    <%= form.text_field :last_name, class: ["block shadow rounded-md border outline-none px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": author.errors[:last_name].none?, "border-red-400 focus:outline-red-600": author.errors[:last_name].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :email %>
    <%= form.text_field :email, class: ["block shadow rounded-md border outline-none px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": author.errors[:email].none?, "border-red-400 focus:outline-red-600": author.errors[:email].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :bio %>
    <%= form.textarea :bio, rows: 4, class: ["block shadow rounded-md border outline-none px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": author.errors[:bio].none?, "border-red-400 focus:outline-red-600": author.errors[:bio].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :website %>
    <%= form.text_field :website, class: ["block shadow rounded-md border outline-none px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": author.errors[:website].none?, "border-red-400 focus:outline-red-600": author.errors[:website].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :avatar %>
    <%= form.file_field :avatar, class: ["block shadow rounded-md border outline-none px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": author.errors[:avatar].none?, "border-red-400 focus:outline-red-600": author.errors[:avatar].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :slug %>
    <%= form.text_field :slug, class: ["block shadow rounded-md border outline-none px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": author.errors[:slug].none?, "border-red-400 focus:outline-red-600": author.errors[:slug].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :twitter_handle %>
    <%= form.text_field :twitter_handle, class: ["block shadow rounded-md border outline-none px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": author.errors[:twitter_handle].none?, "border-red-400 focus:outline-red-600": author.errors[:twitter_handle].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :linkedin_url %>
    <%= form.text_field :linkedin_url, class: ["block shadow rounded-md border outline-none px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": author.errors[:linkedin_url].none?, "border-red-400 focus:outline-red-600": author.errors[:linkedin_url].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :github_username %>
    <%= form.text_field :github_username, class: ["block shadow rounded-md border outline-none px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": author.errors[:github_username].none?, "border-red-400 focus:outline-red-600": author.errors[:github_username].any?}] %>
  </div>

  <div class="my-5">
    <%#= form.number_field :status, class: ["block shadow rounded-md border outline-none px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": author.errors[:status].none?, "border-red-400 focus:outline-red-600": author.errors[:status].any?}] %>
    <%= form.label :status %>
    <%= form.select :status, Author.statuses.keys, class: ["block shadow rounded-md border outline-none px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": author.errors[:status].none?, "border-red-400 focus:outline-red-600": author.errors[:status].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :role %>
    <!-- <%= form.number_field :role, class: ["block shadow rounded-md border outline-none px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": author.errors[:role].none?, "border-red-400 focus:outline-red-600": author.errors[:role].any?}] %> -->
    <%= form.select :role, Author.roles.keys, class: ["block shadow rounded-md border outline-none px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": author.errors[:role].none?, "border-red-400 focus:outline-red-600": author.errors[:role].any?}] %>
  
  </div>

  <div class="my-5">
    <%= form.label :deleted_at %>
    <%= form.datetime_field :deleted_at, class: ["block shadow rounded-md border outline-none px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": author.errors[:deleted_at].none?, "border-red-400 focus:outline-red-600": author.errors[:deleted_at].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
