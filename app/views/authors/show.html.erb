<% content_for :head do %>
  <% page_desc = @author.bio.presence || "Articles by #{@author.full_name} on Edo CMS." %>
  <% set_meta_tags(
       title:       @author.full_name,
       description: page_desc,
       canonical:   author_url(@author),
       og: { title: @author.full_name, type: "profile", url: author_url(@author),
             description: page_desc, image: og_image_url_for(@author) }
     ) %>
  <%= render "shared/json_ld", schema: schema_author_for(@author).merge(
        "@context"         => "https://schema.org",
        "description"      => page_desc,
        "mainEntityOfPage" => { "@type" => "WebPage", "@id" => author_url(@author) }
      ) %>
<% end %>

<div class="md:w-2/3 w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <h1 class="font-bold text-4xl">Showing author</h1>

  <%= render @author %>

  <%= link_to "Edit this author", edit_author_path(@author), class: "mt-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
</div>
