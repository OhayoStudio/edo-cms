<% content_for :title, "Authors" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div id="authors" class="min-w-full">
    <% if @authors.any? %>
      <% @authors.each do |author| %>
        <%= render author %>
        <p>
          <%= link_to "Show this author", author, class: "ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
        </p>
      <% end %>
    <% else %>
      <p class="text-center my-10">No authors found.</p>
    <% end %>
  </div>
</div>
