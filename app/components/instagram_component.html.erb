<%# app/views/instagram/liked_posts.html.erb %>

<div class="container mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold mb-6 text-gray-800">Instagram Likes Gallery</h1>
  
  <% if @liked_posts && @liked_posts.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6">
      <% @liked_posts.each do |post| %>
        <div class="bg-white rounded-lg overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300 transform hover:-translate-y-1">
          <div class="relative">
            <% if post['media_type'] == 'IMAGE' || post['media_type'] == 'CAROUSEL_ALBUM' %>
              <img src="<%= post['media_url'] || post['thumbnail_url'] %>" 
                   class="w-full h-48 object-cover" 
                   alt="<%= post['caption']&.truncate(20) || 'Instagram post' %>">
            <% elsif post['media_type'] == 'VIDEO' %>
              <div class="relative">
                <img src="<%= post['thumbnail_url'] %>" 
                     class="w-full h-48 object-cover" 
                     alt="<%= post['caption']&.truncate(20) || 'Instagram video' %>">
                <div class="absolute inset-0 flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-white" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd" />
                  </svg>
                </div>
              </div>
            <% end %>
          </div>
          
          <div class="p-4">
            <p class="text-sm text-gray-700 truncate">
              <%= post['caption']&.truncate(50) || 'No caption' %>
            </p>
            <p class="text-xs text-gray-500 mt-1">@<%= post['username'] %></p>
            
            <div class="flex justify-between items-center mt-3">
              <span class="text-xs text-gray-400">
                <%= Time.parse(post['timestamp']).strftime('%b %d, %Y') %>
              </span>
              <a href="<%= post['permalink'] %>" target="_blank" 
                 class="text-xs bg-gradient-to-r from-purple-500 to-pink-500 hover:from-purple-600 hover:to-pink-600 text-white py-1 px-3 rounded-full">
                View
              </a>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-blue-100 border-l-4 border-blue-500 text-blue-700 p-4 rounded">
      <p>No liked posts found or there was an error fetching your liked posts.</p>
    </div>
  <% end %>
</div>