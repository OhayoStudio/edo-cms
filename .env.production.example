# Production environment variables for EDO CMS.
# Copy relevant values to your shell / secrets manager before running:
#   bin/kamal deploy
#
# All values marked [REQUIRED] must be set. [OPTIONAL] vars are used only
# if the corresponding feature is active.

# --- Kamal / Registry ---
KAMAL_REGISTRY_PASSWORD=          # [REQUIRED] Container registry token (write:packages scope)

# --- Rails ---
RAILS_MASTER_KEY=                  # [REQUIRED] contents of config/master.key (do not commit that file)

# --- Database ---
EDO_CMS_DATABASE_PASSWORD=         # [REQUIRED] password for the 'edo_cms' postgres user
DB_HOST=                           # [OPTIONAL] defaults to 127.0.0.1 / host.docker.internal in Kamal

# --- Host ---
APPLICATION_HOST=                  # [REQUIRED] the public hostname (e.g. example.com)

# --- Active Storage ---
ACTIVE_STORAGE_SERVICE=            # local | gcs_production | gcs_staging
GCS_BUCKET=                        # [REQUIRED if using GCS]
GCS_CREDENTIALS_PATH=              # [REQUIRED if using GCS] path to service-account JSON

# --- YouTube (optional, enables video metadata fetch in admin) ---
YOUTUBE_API_KEY=                   # [OPTIONAL]

# --- Instagram story sharing (optional, admin → edit article) ---
# Story PNG/MP4 download works with no config. Direct "Share to Instagram"
# additionally needs a Graph API token + business account, and the export
# files must be downloadable by Instagram over HTTPS (so APPLICATION_HOST
# must be public; use ngrok in dev). MP4 generation requires ffmpeg.
INSTAGRAM_ACCESS_TOKEN=            # [OPTIONAL] Graph API long-lived token; enables direct sharing
INSTAGRAM_USER_ID=                 # [OPTIONAL] Instagram business account ID
FFMPEG_PATH=                       # [OPTIONAL] ffmpeg path; needs a libfreetype build (drawtext). macOS: brew install homebrew-ffmpeg/ffmpeg/ffmpeg-full
STORY_FONT_SERIF=                  # [OPTIONAL] .ttf for the story title (auto-detected on macOS/Linux)
STORY_FONT_SANS=                   # [OPTIONAL] .ttf for story captions (auto-detected on macOS/Linux)

# --- Sentry (optional error reporting) ---
SENTRY_DSN=                        # [OPTIONAL]

# --- Deploy (used by config/deploy.yml templating) ---
DEPLOY_HOST=                       # [OPTIONAL] used by config/deploy.yml if not edited by hand

# --- Umami analytics (self-hosted via Kamal accessory) ---
UMAMI_HOST=                        # [OPTIONAL] subdomain serving Umami, e.g. analytics.example.com
UMAMI_DB_PASSWORD=                 # [REQUIRED if Umami enabled] postgres password for the umami role
UMAMI_APP_SECRET=                  # [REQUIRED if Umami enabled] 32+ random chars (rails secret)
