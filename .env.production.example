# Production environment variables for sepiabraun.com
# Copy relevant values to your shell / secrets manager before running:
#   bin/kamal deploy
#
# All values marked [REQUIRED] must be set. [OPTIONAL] vars are used only
# if the corresponding feature is active.

# --- Kamal / Registry ---
KAMAL_REGISTRY_PASSWORD=          # [REQUIRED] GitHub Container Registry token (write:packages scope)

# --- Rails ---
RAILS_MASTER_KEY=                  # [REQUIRED] contents of config/master.key (do not commit that file)

# --- Database ---
EDO_DATABASE_PASSWORD=             # [REQUIRED] password for the 'edo' postgres user on the droplet
                                   # Run script/setup_production.sh once to create the user + 4 databases

# --- AI / Anthropic ---
ANTHROPIC_API_KEY=                 # [REQUIRED] Claude API key (writing assistant)
GEMINI_API_KEY=                    # [REQUIRED] Gemini API key (AI thumbnail enhancement)

# --- Instagram ---
INSTAGRAM_ACCESS_TOKEN=            # [OPTIONAL] long-lived token (60-day expiry, renew manually)
INSTAGRAM_USER_ID=                 # [OPTIONAL] Instagram business account user ID

# --- Flickr ---
FLICKR_API_KEY=                    # [OPTIONAL]
FLICKR_API_SECRET=                 # [OPTIONAL]
FLICKR_ACCESS_TOKEN=               # [OPTIONAL]
FLICKR_ACCESS_TOKEN_SECRET=        # [OPTIONAL]
FLICKR_USER_NSID=                  # [OPTIONAL]

# --- YouTube ---
YOUTUBE_API_KEY=                   # [OPTIONAL] used to fetch video metadata

# --- Google Cloud Storage ---
# GCS_BUCKET and ACTIVE_STORAGE_SERVICE are set in config/deploy.yml (no action needed here)
# The service account below must have Storage Object Admin role on the GCS bucket.
# Create two buckets in GCP: sepiabraun-production and sepiabraun-staging.

# --- Google APIs ---
GOOGLE_CLIENT_ID=                  # [OPTIONAL] OAuth (if Google login is enabled)
GOOGLE_CLIENT_SECRET=              # [OPTIONAL]
GOOGLE_API_KEY=                    # [OPTIONAL] restricted key (Maps/YouTube)
GOOGLE_SERVICE_ACCOUNT_JSON=       # [REQUIRED] base64-encoded service account JSON for Search Console
                                   # Generate: base64 -i service_account.json | tr -d '\n'

# --- Pexels ---
PEXELS_API_KEY=                    # [OPTIONAL] stock photo search

# --- Analytics (Umami) ---
UMAMI_WEBSITE_ID=                  # [OPTIONAL] set after deploying Umami (see issue #223)
